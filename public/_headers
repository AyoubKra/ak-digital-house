# Cloudflare Pages cache headers

# HTML — always revalidate so updates are picked up immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Astro-generated assets have content-hash in filename — safe to cache for 1 year
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Images
/favicon.png
  Cache-Control: public, max-age=31536000, immutable
/logo-color.png
  Cache-Control: public, max-age=31536000, immutable
/logo-white.png
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/tech/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable

# robots.txt and sitemap — short cache so crawlers see updates quickly
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap-index.xml
  Cache-Control: public, max-age=86400
/sitemap-*.xml
  Cache-Control: public, max-age=86400
