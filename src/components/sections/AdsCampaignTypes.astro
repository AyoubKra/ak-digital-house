---
---

<section class="act-section">
  <div class="act-inner">

    <!-- Header -->
    <div class="act-header">
      <span class="act-eyebrow">Campaign Types</span>
      <h2 class="act-h2">Three Ways We Drive Customers to Your Door</h2>
      <p class="act-sub">Pick the type that fits your business. We'll confirm the fit on your strategy call.</p>
    </div>

    <!-- Tab selector -->
    <div class="act-tabs" role="tablist">
      <button class="act-tab act-tab--active" role="tab" aria-selected="true" data-tab="local">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Local Lead Gen
      </button>
      <button class="act-tab" role="tab" aria-selected="false" data-tab="ecom">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        Ecommerce
      </button>
      <button class="act-tab" role="tab" aria-selected="false" data-tab="b2b">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        B2B & High-Ticket
      </button>
    </div>

    <!-- Panels -->
    <div class="act-panels">

      <!-- Panel: Local -->
      <div class="act-panel act-panel--active" data-panel="local" role="tabpanel">
        <div class="act-panel-left">
          <p class="act-panel-for">For service businesses in the Triangle</p>
          <p class="act-panel-desc">You need the phone to ring. We build Google Search and Performance Max campaigns that put you in front of every local customer already searching for what you do.</p>
          <ul class="act-bullets">
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Google Search targeting buyer-intent keywords in your area
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Performance Max across Google, YouTube, and Maps
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Call tracking on every campaign — know which ad earned the call
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Geo-targeted to your service radius — zero wasted clicks
            </li>
          </ul>
          <a href="#contact" class="act-cta">Start Generating Leads →</a>
        </div>
        <div class="act-panel-right">
          <div class="act-stat-card">
            <div class="act-stat-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <p class="act-stat-num">7 days</p>
            <p class="act-stat-label">Average time to first inbound lead</p>
            <div class="act-stat-divider"></div>
            <div class="act-stat-row">
              <div>
                <p class="act-stat-mini-num">100%</p>
                <p class="act-stat-mini-label">Account ownership — yours from day one</p>
              </div>
              <div>
                <p class="act-stat-mini-num">0</p>
                <p class="act-stat-mini-label">Setup fees or long-term contracts</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel: Ecom -->
      <div class="act-panel" data-panel="ecom" role="tabpanel">
        <div class="act-panel-left">
          <p class="act-panel-for">For online stores ready to scale</p>
          <p class="act-panel-desc">You want a measurable return on every ad dollar. We build Google Shopping, Meta Advantage+, and TikTok systems that scale only what's profitable — and kill what isn't.</p>
          <ul class="act-bullets">
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Google Shopping with optimised product feeds for higher CTR
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Meta Advantage+ for Facebook & Instagram conversions
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Server-side conversion tracking — iOS won't kill your data
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Weekly ROAS reporting with creative assistance included
            </li>
          </ul>
          <a href="#contact" class="act-cta">Launch My Store Ads →</a>
        </div>
        <div class="act-panel-right">
          <div class="act-stat-card">
            <div class="act-stat-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <p class="act-stat-num">3 platforms</p>
            <p class="act-stat-label">Google · Meta · TikTok — managed in one place</p>
            <div class="act-stat-divider"></div>
            <div class="act-stat-row">
              <div>
                <p class="act-stat-mini-num">Weekly</p>
                <p class="act-stat-mini-label">ROAS reporting, no jargon</p>
              </div>
              <div>
                <p class="act-stat-mini-num">0 lock-in</p>
                <p class="act-stat-mini-label">Cancel any month, no penalty</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel: B2B -->
      <div class="act-panel" data-panel="b2b" role="tabpanel">
        <div class="act-panel-left">
          <p class="act-panel-for">For startups and consultancies selling $5K+ deals</p>
          <p class="act-panel-desc">Your buyer is a decision-maker, not an impulse buyer. We build LinkedIn, Google Search, and retargeting systems that surface decision-grade leads and filter noise before it hits your inbox.</p>
          <ul class="act-bullets">
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              LinkedIn Ads with title, industry, and company-size targeting
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Google Search for high-intent buying keywords
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              Retargeting funnels that nurture cold visitors into booked calls
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              HubSpot / CRM integration + pipeline-value reporting
            </li>
          </ul>
          <a href="#contact" class="act-cta">Build My B2B Pipeline →</a>
        </div>
        <div class="act-panel-right">
          <div class="act-stat-card">
            <div class="act-stat-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <p class="act-stat-num">$5K+</p>
            <p class="act-stat-label">Average deal size we're built to target</p>
            <div class="act-stat-divider"></div>
            <div class="act-stat-row">
              <div>
                <p class="act-stat-mini-num">Quality</p>
                <p class="act-stat-mini-label">Over quantity — fewer, better leads</p>
              </div>
              <div>
                <p class="act-stat-mini-num">CRM-ready</p>
                <p class="act-stat-mini-label">Leads flow straight into your pipeline</p>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .act-section { background: #1a1c1e; padding: 80px 24px; }
  .act-inner { max-width: 1000px; margin: 0 auto; display: flex; flex-direction: column; gap: 36px; }

  /* Header */
  .act-header { text-align: center; }
  .act-eyebrow { display: inline-block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #d91e45; background: rgba(217,30,69,0.12); padding: 4px 12px; border-radius: 999px; margin-bottom: 16px; }
  .act-h2 { font-size: clamp(1.6rem, 3vw, 2.1rem); font-weight: 800; color: #ffffff; line-height: 1.2; letter-spacing: -0.02em; margin: 0 0 12px; }
  .act-sub { font-size: 0.9375rem; color: #9ca3af; margin: 0; }

  /* Tabs */
  .act-tabs { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
  .act-tab { display: flex; align-items: center; gap: 7px; padding: 10px 20px; border-radius: 999px; border: 1.5px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.06); color: #9ca3af; font-size: 0.875rem; font-weight: 600; cursor: pointer; transition: all 0.18s ease; font-family: inherit; }
  .act-tab:not(.act-tab--active):hover { border-color: #d91e45; color: #ffffff; background: rgba(217,30,69,0.1); }
  .act-tab--active { background: #d91e45; border-color: #d91e45; color: #ffffff; }
  .act-tab--active svg { stroke: #ffffff; }

  /* Panels */
  .act-panels { position: relative; }
  .act-panel { display: none; grid-template-columns: 1fr 360px; gap: 40px; align-items: start; opacity: 0; transform: translateY(8px); transition: opacity 0.25s ease, transform 0.25s ease; }
  .act-panel--active { display: grid; opacity: 1; transform: translateY(0); }

  /* Panel left */
  .act-panel-for { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #d91e45; margin: 0 0 10px; }
  .act-panel-desc { font-size: 0.9375rem; color: #d1d5db; line-height: 1.7; margin: 0 0 22px; }
  .act-bullets { list-style: none; padding: 0; margin: 0 0 28px; display: flex; flex-direction: column; gap: 10px; }
  .act-bullets li { display: flex; align-items: flex-start; gap: 10px; font-size: 0.875rem; color: #e5e7eb; line-height: 1.5; }
  .act-bullets li svg { flex-shrink: 0; margin-top: 2px; }
  .act-cta { display: inline-block; background: #d91e45; color: #ffffff; font-size: 0.9rem; font-weight: 700; padding: 13px 28px; border-radius: 999px; text-decoration: none; transition: background 0.18s ease; }
  .act-cta:hover { background: #b81a3a; }

  /* Panel right — stat card */
  .act-stat-card { background: #242729; border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 28px 24px; display: flex; flex-direction: column; gap: 6px; }
  .act-stat-icon { width: 52px; height: 52px; background: rgba(217,30,69,0.15); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; }
  .act-stat-num { font-size: 2rem; font-weight: 800; color: #ffffff; margin: 0; letter-spacing: -0.03em; }
  .act-stat-label { font-size: 0.82rem; color: #9ca3af; margin: 0; line-height: 1.5; }
  .act-stat-divider { height: 1px; background: rgba(255,255,255,0.1); margin: 16px 0; }
  .act-stat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .act-stat-mini-num { font-size: 1rem; font-weight: 800; color: #ffffff; margin: 0 0 3px; }
  .act-stat-mini-label { font-size: 0.75rem; color: #9ca3af; margin: 0; line-height: 1.4; }

  /* Mobile */
  @media (max-width: 720px) {
    .act-panel--active { grid-template-columns: 1fr; }
    .act-panel-right { order: -1; }
    .act-stat-card { padding: 20px 18px; }
    .act-tabs { gap: 6px; }
    .act-tab { padding: 9px 14px; font-size: 0.82rem; }
  }
  @media (max-width: 480px) {
    .act-section { padding: 56px 16px; }
    .act-tabs { flex-direction: column; align-items: stretch; }
    .act-tab { justify-content: center; border-radius: 10px; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.act-tab');
  const panels = document.querySelectorAll<HTMLElement>('.act-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      tabs.forEach(t => {
        t.classList.remove('act-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => {
        p.classList.remove('act-panel--active');
        p.style.display = 'none';
      });

      tab.classList.add('act-tab--active');
      tab.setAttribute('aria-selected', 'true');

      const activePanel = document.querySelector<HTMLElement>(`.act-panel[data-panel="${target}"]`);
      if (activePanel) {
        activePanel.style.display = 'grid';
        // Trigger transition after display change
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            activePanel.classList.add('act-panel--active');
          });
        });
      }
    });
  });
</script>
