---
interface Props {
  headline: string;
  subheadline: string;
  cta_text?: string;
  cta_href?: string;
  background?: 'gradient' | 'white' | 'dark';
}

const {
  headline,
  subheadline,
  cta_text,
  cta_href = '#',
  background = 'gradient',
} = Astro.props;
---

<section class:list={['hero', `hero--${background}`]}>
  <div class="hero-inner">
    <h1 class="hero-headline">{headline}</h1>
    <p class="hero-subheadline">{subheadline}</p>
    {cta_text && (
      <a href={cta_href} class="hero-cta">{cta_text}</a>
    )}
  </div>
</section>

<style>
  .hero {
    width: 100%;
    padding: 80px 24px;
    text-align: center;
  }

  .hero--gradient {
    background: linear-gradient(160deg, #fde8ed 0%, #ffffff 60%);
  }

  .hero--white {
    background: #ffffff;
  }

  .hero--dark {
    background: #1A1C1E;
  }

  .hero--dark .hero-headline,
  .hero--dark .hero-subheadline {
    color: #ffffff;
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .hero-headline {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #242729;
    line-height: 1.2;
    margin: 0;
  }

  .hero-subheadline {
    font-size: clamp(0.9375rem, 1vw, 1rem);
    color: #555;
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: #D91E45;
    color: #ffffff;
    font-size: 1rem;
    font-weight: 500;
    border-radius: 1000px;
    border: 2px solid #D91E45;
    text-decoration: none;
    transition: transform 0.2s ease, filter 0.2s ease, box-shadow 0.2s ease;
  }

  .hero-cta:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(217, 30, 69, 0.25);
    color: #ffffff;
  }

  @media (max-width: 640px) {
    .hero {
      padding: 48px 16px;
    }
  }
</style>
