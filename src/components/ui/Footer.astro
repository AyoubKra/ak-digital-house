---
const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">AK Digital House</a>
      <p class="footer-desc">
        We design and build digital experiences that help businesses grow. Clean design, solid code, real results.
      </p>
    </div>

    <div class="footer-links">
      <h4 class="footer-heading">Quick Links</h4>
      <ul>
        {quickLinks.map(link => (
          <li><a href={link.href} class="footer-link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="footer-contact">
      <h4 class="footer-heading">Get In Touch</h4>
      <p class="footer-desc">Ready to start your project?</p>
      <a href="/contact" class="footer-cta">Contact Us</a>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {year} AK Digital House. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: #1A1C1E;
    color: #ffffff;
    padding: 64px 24px 0;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
  }

  .footer-logo {
    font-size: 1.125rem;
    font-weight: 700;
    color: #F3D677;
    text-decoration: none;
    display: inline-block;
    margin-bottom: 16px;
  }

  .footer-desc {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.6;
    margin: 0;
  }

  .footer-heading {
    font-size: 0.875rem;
    font-weight: 700;
    color: #F3D677;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 16px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 0.9375rem;
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: #ffffff;
  }

  .footer-cta {
    display: inline-flex;
    align-items: center;
    margin-top: 16px;
    padding: 10px 24px;
    background-color: #F3D677;
    color: #202020;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: filter 0.2s ease;
  }

  .footer-cta:hover {
    filter: brightness(0.95);
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 0;
    border-top: 1px solid rgba(255,255,255,0.1);
    font-size: 0.875rem;
    color: rgba(255,255,255,0.4);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer-brand {
      grid-column: auto;
    }
  }
</style>
