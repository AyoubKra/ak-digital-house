    <script>
    (function () {
      function isMobile() { return window.innerWidth <= 768; }
      function initMobileFaq() {
        if (!isMobile()) return;
        var nav = document.querySelector('.faq-nav');
        var panelsContainer = document.querySelector('.faq-panels');
        if (!nav || !panelsContainer || nav.dataset.mobileInit) return;
        nav.dataset.mobileInit = '1';
        var labels = Array.from(nav.querySelectorAll('.faq-navitem'));
        var panels = Array.from(panelsContainer.querySelectorAll('.faq-panel'));
        labels.forEach(function (label, i) {
          if (panels[i]) label.insertAdjacentElement('afterend', panels[i]);
        });
        panels.forEach(function (p) { p.style.display = 'none'; });
        labels.forEach(function (label, i) {
          label.addEventListener('click', function () {
            if (!isMobile()) return;
            var panel = panels[i];
            if (!panel) return;
            var isOpen = panel.style.display !== 'none';
            panel.style.display = isOpen ? 'none' : 'block';
            label.classList.toggle('is-open', !isOpen);
          });
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initMobileFaq);
      } else {
        initMobileFaq();
      }
    })();
    </script>

