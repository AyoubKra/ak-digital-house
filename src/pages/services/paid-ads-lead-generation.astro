---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/ui/Navigation.astro';
import Footer from '../../components/ui/Footer.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title="Paid Ads & Lead Generation | AK Digital House — Raleigh Digital Marketing Agency"
      description="Google Ads, Meta Ads, and LinkedIn Ads management for Raleigh small businesses. Live in 7 business days. Transparent pricing from $750/mo. No contracts."
      image="/live-Looker-Studio-dashboard-2026.webp"
    />
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Paid Ads & Lead Generation",
      "provider": {
        "@type": "LocalBusiness",
        "name": "AK Digital House",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Raleigh",
          "addressRegion": "NC",
          "addressCountry": "US"
        }
      },
      "areaServed": ["Raleigh","Cary","Durham","Apex","Wake Forest","Morrisville","Chapel Hill","Holly Springs","Fuquay-Varina"],
      "description": "Google Ads, Meta Ads, and LinkedIn Ads management for Raleigh small businesses. Live in 7 business days."
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://akdigitalhouse.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Services",
          "item": "https://akdigitalhouse.com/services/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "Paid Ads & Lead Generation",
          "item": "https://akdigitalhouse.com/services/paid-ads-lead-generation/"
        }
      ]
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I know if paid ads are right for my business right now?",
          "acceptedAnswer": { "@type": "Answer", "text": "Paid ads work when two things are true: your website converts visitors into leads or sales, and you have a budget you can sustain for at least 90 days. If your site is slow, unclear, or broken — ads will burn money. We'll tell you honestly on the strategy call if we think you're not ready yet." }
        },
        {
          "@type": "Question",
          "name": "What do I need to have ready before we start?",
          "acceptedAnswer": { "@type": "Answer", "text": "A working website or landing page, a Google or Meta account (we can create it if you don't have one), and your monthly ad budget ready to go. That's it. We handle everything else — copy, targeting, tracking, creative direction." }
        },
        {
          "@type": "Question",
          "name": "How long does it take to launch?",
          "acceptedAnswer": { "@type": "Answer", "text": "7 business days from signed agreement to live campaign. That includes account setup, conversion tracking, ad copy, audience targeting, and your first round of creative." }
        },
        {
          "@type": "Question",
          "name": "Do I need to know anything about ads to work with you?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nothing. You don't need to understand bid strategies, Quality Scores, or campaign types. You need to understand your business and your customers — we handle the rest. We explain everything in plain English, and we never use jargon to justify our fees." }
        },
        {
          "@type": "Question",
          "name": "Can you work with my existing ad accounts?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. If you've been running ads yourself or with another agency, we'll audit the account on the strategy call and tell you exactly what's working, what's wasting money, and what we'd change." }
        },
        {
          "@type": "Question",
          "name": "What's the difference between my ad budget and your management fee?",
          "acceptedAnswer": { "@type": "Answer", "text": "They are two completely separate costs. Your ad budget goes directly to Google, Meta, or LinkedIn — you pay them, not us. Our management fee is what you pay AK Digital House to build, run, and optimize the campaigns. We never take a percentage of your ad spend." }
        },
        {
          "@type": "Question",
          "name": "How much should I spend on ads each month?",
          "acceptedAnswer": { "@type": "Answer", "text": "For local service businesses in the Triangle, a realistic starting point is $500–$1,500/month in ad spend. Ecommerce stores typically start at $1,500–$3,000/month. B2B companies with high-ticket services can often start at $1,000/month and still see results. We'll give you a specific recommendation on the strategy call based on your market and goals." }
        },
        {
          "@type": "Question",
          "name": "Why do you charge a flat fee instead of a percentage of ad spend?",
          "acceptedAnswer": { "@type": "Answer", "text": "Because percentage models create a conflict of interest. If we charge 15% of your ad budget, we make more money when you spend more — even if spending more isn't the right call for your business. A flat fee means our incentive is your results, not your budget size." }
        },
        {
          "@type": "Question",
          "name": "Are there any setup fees?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Setup is included in your first month's management fee. There are no hidden onboarding fees, account creation fees, or creative fees on top of what's listed on the pricing page." }
        },
        {
          "@type": "Question",
          "name": "Is there a minimum contract length?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. Month-to-month, cancel with 30 days notice. We'd rather earn your business every month than trap you in a contract." }
        },
        {
          "@type": "Question",
          "name": "Do you offer any free trials or promotions?",
          "acceptedAnswer": { "@type": "Answer", "text": "Two, depending on how you come in. If you're launching a website with us, your first 30 days of ad management are on us. If you're coming in for ads only, stay for two months and month three is free. You only ever pay ad spend directly to the platform — never to us." }
        },
        {
          "@type": "Question",
          "name": "When will I see my first leads?",
          "acceptedAnswer": { "@type": "Answer", "text": "Campaigns go live in 7 business days. First leads typically follow within the first 1–2 weeks depending on your market, budget, and offer. Profitable, consistent lead flow usually takes 30–60 days as the campaign optimizes on real data." }
        },
        {
          "@type": "Question",
          "name": "Can you guarantee a specific number of leads per month?",
          "acceptedAnswer": { "@type": "Answer", "text": "No — and any agency that does is lying to you. Lead volume depends on your market size, your budget, your competition, and your offer. What we guarantee is the work: fast launch, tight targeting, weekly optimization, and full transparency on what's happening and why." }
        },
        {
          "@type": "Question",
          "name": "How do I know if the ads are actually working?",
          "acceptedAnswer": { "@type": "Answer", "text": "You get a live Looker Studio dashboard from day one, updated daily. It shows your spend, clicks, leads, cost-per-lead, and platform breakdowns in plain English. You'll also get a written Friday summary every week with what happened, what we changed, and what we're testing next." }
        },
        {
          "@type": "Question",
          "name": "What if results are slow in the first month?",
          "acceptedAnswer": { "@type": "Answer", "text": "The first 30 days are a learning phase for the platform's algorithm. We typically see the best performance in weeks 3–8 as the campaign gathers real conversion data. We'll tell you in week two if something isn't showing early signals — and we'll adjust before you ask." }
        },
        {
          "@type": "Question",
          "name": "My competitor seems to be everywhere on Google. Can you beat them?",
          "acceptedAnswer": { "@type": "Answer", "text": "Often yes, but not always through outspending them. We win by finding the keywords and audiences they're ignoring, writing ads that convert better than theirs, and building landing pages that don't leak traffic. A smarter campaign beats a bigger budget more often than you'd think." }
        },
        {
          "@type": "Question",
          "name": "Which platform is right for my business — Google or Meta?",
          "acceptedAnswer": { "@type": "Answer", "text": "Google Ads captures demand — people who are already searching for what you offer. Meta Ads create demand — people who don't know you yet but fit your ideal customer profile. Service businesses and B2B companies usually start with Google. Ecommerce and consumer brands usually start with Meta." }
        },
        {
          "@type": "Question",
          "name": "What is Performance Max and should I be using it?",
          "acceptedAnswer": { "@type": "Answer", "text": "Performance Max is Google's AI-powered campaign type that runs ads across Search, YouTube, Display, Gmail, Maps, and Discover from a single campaign. It can be powerful when set up correctly — but it needs strong conversion tracking, good creative assets, and active human oversight to avoid wasting budget on low-quality placements." }
        },
        {
          "@type": "Question",
          "name": "Do you build landing pages for the campaigns?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Growth and Scale tiers include dedicated landing pages built on our fast Astro stack — same 95+ Lighthouse score standard as our full websites. A campaign landing page built for conversion will outperform sending traffic to your homepage almost every time." }
        },
        {
          "@type": "Question",
          "name": "What about retargeting? Do you do that?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes, and we include it in every campaign from launch. Retargeting shows your ads to people who visited your site but didn't convert — typically at a much lower cost-per-lead than cold traffic. It's one of the most efficient uses of a small ad budget." }
        },
        {
          "@type": "Question",
          "name": "Can you run ads if I don't have a website yet?",
          "acceptedAnswer": { "@type": "Answer", "text": "We can, but we'll build a landing page first. Sending paid traffic anywhere without a conversion-optimised destination is burning money. If you don't have a site yet, talk to us about our website design and development service — launch your site with us and your first 30 days of ad management are on us." }
        },
        {
          "@type": "Question",
          "name": "Who will actually be running my campaigns?",
          "acceptedAnswer": { "@type": "Answer", "text": "Ayoub Kra — the founder. You won't be handed off to a junior account manager or an offshore team. Every campaign AKDH takes on is managed directly. That's why we limit the number of active clients we take at any time." }
        },
        {
          "@type": "Question",
          "name": "How do we communicate? How often will I hear from you?",
          "acceptedAnswer": { "@type": "Answer", "text": "You get a live dashboard you can check any time. Every Friday you get a written performance summary — what happened, what changed, what's next. And you can email or message directly any time — you'll hear back within one business day, usually same day." }
        },
        {
          "@type": "Question",
          "name": "Do I own my ad accounts and campaign data?",
          "acceptedAnswer": { "@type": "Answer", "text": "Yes. Always. Accounts are created in your name from day one. We operate as an authorized manager. If you ever leave, you keep everything — campaigns, audiences, conversion data, creative assets. No hostage-taking." }
        },
        {
          "@type": "Question",
          "name": "Can I make changes to the ads myself?",
          "acceptedAnswer": { "@type": "Answer", "text": "We'd ask you to run changes through us first — not to protect our work, but because changes made outside of the optimization cycle can reset the algorithm's learning phase and cost you momentum." }
        },
        {
          "@type": "Question",
          "name": "You're a newer agency. Why should I trust you with my ad budget?",
          "acceptedAnswer": { "@type": "Answer", "text": "Before launching AKDH, I ran campaigns across 50+ projects on Fiverr and Upwork — five-star rated, with real results. I built this agency because I wanted to do the same work with guaranteed timelines, direct client relationships, and local accountability. You're not funding my learning curve." }
        },
        {
          "@type": "Question",
          "name": "What if I've been burned by an agency before?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most of our clients have been. The pattern is usually the same: long contract, slow start, vague reporting, and a sales rep who disappears after you sign. Our answer to that is the opposite on every point — no contract, 7-day launch, live dashboard, and you talk directly to the person doing the work." }
        },
        {
          "@type": "Question",
          "name": "Do you work with businesses outside Raleigh?",
          "acceptedAnswer": { "@type": "Answer", "text": "Our focus is the Triangle — Raleigh, Cary, Durham, Apex, Wake Forest, Morrisville, Chapel Hill, Holly Springs, Fuquay-Varina. We know these markets, we know the competition, and we can meet in person. We do take select remote clients when the fit is strong, but local always comes first." }
        },
        {
          "@type": "Question",
          "name": "How do I know you won't take my money and disappear?",
          "acceptedAnswer": { "@type": "Answer", "text": "You own your ad accounts from day one. Your budget goes directly to Google or Meta — not through us. There's nothing to disappear with. And you can cancel anytime. The only thing keeping you as a client is results." }
        }
      ]
    }
    </script>
  </head>
  <body>
    <Navigation />

    <main>

      <!-- ─── SECTION 1: HERO ─── -->
      <section class="hero-section">
        <div class="hero-inner">
          <!-- Left: Content -->
          <div class="hero-content">
            <span class="hero-label">Paid Ads &amp; Lead Generation</span>
            <h1 class="hero-subheadline"><span class="hero-accent">Stop Paying for Clicks. </span>Start Paying for Customers.</h1>
            <p class="hero-desc">

             Raleigh & suburbs small businesses spend $2,500 a month on Google Ads, get 80 clicks, and one phone call. The other 79 went somewhere else. We build profitable Google and Meta campaigns for the Triangle — live in 7 business days, with the first leads landing in your inbox before most agencies have finished the kickoff call.
</p>
            <div class="hero-buttons">
              <a href="#contact" class="btn-primary">Book a Free Strategy Call →</a>
              <a href="#pricing" class="btn-secondary">See Our Pricing ↓</a>
            </div>
            <!-- Trust badges -->
            <div class="hero-badges">
              <div class="badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Live in 7 Days</span>
              </div>
              <div class="badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <span>FREE 30 Days Ads Management</span>
              </div>
              <div class="badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span>Cancel Anytime</span>
              </div>
            </div>
          </div>
          <!-- Hero image — single element, repositioned via CSS for mobile/desktop -->
          <div class="hero-image-wrap">
            <img src="/PPC.webp" alt="Google Ads and Meta Ads management for Raleigh small businesses — AK Digital House" class="hero-image" fetchpriority="high" decoding="async" width="420" height="504" />
          </div>
        </div>
      </section>

      <!-- ─── SECTION 2: PAIN FRAMING ─── -->
      <section class="ai-section">
        <div class="ai-inner">

          <span class="ai-eyebrow">The Problem</span>
          <h2 class="ai-h2">Most agencies sell you clicks.<br/>You need customers.</h2>
          <p class="ai-intro">You did not start your business to study dashboards at midnight. Most agencies hand you a report full of impressions and CTRs — while your phone stays quiet. Here is what actually happens when a typical agency runs your ads.</p>

          <!-- Comparison infographic -->
          <table class="cmp-table" aria-label="Agency comparison: Typical Agency vs AK Digital House">
            <colgroup>
              <col class="cmp-col-side" />
              <col class="cmp-col-center" />
              <col class="cmp-col-side" />
            </colgroup>
            <thead>
              <tr>
                <th class="cmp-header cmp-header-left" scope="col"><span>TYPICAL AGENCY</span></th>
                <th class="cmp-header cmp-header-vs" scope="col"><span class="sr-only">Criteria</span></th>
                <th class="cmp-header cmp-header-right" scope="col"><span>AK DIGITAL HOUSE</span></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="cmp-cell cmp-cell-left cmp-top"><span class="cmp-x-icon" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span><p class="cmp-row-text">90-day onboarding before a single ad runs</p></td>
                <th class="cmp-cell cmp-cell-center" scope="row"><span class="sr-only">Speed</span><div class="cmp-icon-wrap" aria-hidden="true"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div></th>
                <td class="cmp-cell cmp-cell-right cmp-top"><span class="cmp-check-icon" aria-hidden="true">&#10003;</span><p class="cmp-row-text">Campaigns live in 7 business days &mdash; or we work for free</p></td>
              </tr>
              <tr>
                <td class="cmp-cell cmp-cell-left"><span class="cmp-x-icon" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span><p class="cmp-row-text">$5,000 setup fee paid before any results</p></td>
                <th class="cmp-cell cmp-cell-center" scope="row"><span class="sr-only">Cost</span><div class="cmp-icon-wrap" aria-hidden="true"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div></th>
                <td class="cmp-cell cmp-cell-right"><span class="cmp-check-icon" aria-hidden="true">&#10003;</span><p class="cmp-row-text">No setup fee &mdash; flat monthly management only</p></td>
              </tr>
              <tr>
                <td class="cmp-cell cmp-cell-left"><span class="cmp-x-icon" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span><p class="cmp-row-text">Reports full of impressions &mdash; not leads or revenue</p></td>
                <th class="cmp-cell cmp-cell-center" scope="row"><span class="sr-only">Reporting</span><div class="cmp-icon-wrap" aria-hidden="true"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div></th>
                <td class="cmp-cell cmp-cell-right"><span class="cmp-check-icon" aria-hidden="true">&#10003;</span><p class="cmp-row-text">Weekly plain-English report: cost per lead, what's next</p></td>
              </tr>
              <tr>
                <td class="cmp-cell cmp-cell-left"><span class="cmp-x-icon" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span><p class="cmp-row-text">They own your ad accounts &mdash; you leave with nothing</p></td>
                <th class="cmp-cell cmp-cell-center" scope="row"><span class="sr-only">Ownership</span><div class="cmp-icon-wrap" aria-hidden="true"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></div></th>
                <td class="cmp-cell cmp-cell-right"><span class="cmp-check-icon" aria-hidden="true">&#10003;</span><p class="cmp-row-text">You own your ad accounts from day one, always</p></td>
              </tr>
              <tr>
                <td class="cmp-cell cmp-cell-left cmp-bottom"><span class="cmp-x-icon" aria-hidden="true"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span><p class="cmp-row-text">Locked into a 12-month contract after month one</p></td>
                <th class="cmp-cell cmp-cell-center" scope="row"><span class="sr-only">Contract</span><div class="cmp-icon-wrap" aria-hidden="true"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div></th>
                <td class="cmp-cell cmp-cell-right cmp-bottom"><span class="cmp-check-icon" aria-hidden="true">&#10003;</span><p class="cmp-row-text">Month-to-month &mdash; cancel anytime, no penalty</p></td>
              </tr>
            </tbody>
          </table>

          <!-- What we bring to the table -->
          <p class="ai-pivot">What we actually do before spending your budget.</p>

          <div class="ai-boxes">
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Your market</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></div>
              </div>
              <p class="ai-box-sub">48-hour competitor audit before launch.</p>
            </div>
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Buyer intent</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
              </div>
              <p class="ai-box-sub">We focus on high-intent keywords — people already looking for what you offer.</p>
            </div>
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Conversion tracking</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
              </div>
              <p class="ai-box-sub">Server-side GA4 + call tracking before launch not after.</p>
            </div>
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Weekly optimization</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></div>
              </div>
              <p class="ai-box-sub">Monday cuts, Friday report — every week, no exceptions.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 2B: HOW WE DO IT ─── -->
      <section class="howwe-section">
        <div class="howwe-inner">

          <!-- Top: centered header -->
          <div class="howwe-header">
            <span class="ai-eyebrow">OUR FEATURE</span>
            <h2 class="howwe-h2">Everything Your Campaign Needs. <span class="howwe-accent">Nothing It Doesn't.</span></h2>
            <p class="howwe-intro">We handle every moving part — so you never have to wonder where your budget went or why the phone isn't ringing.</p>
          </div>

          <!-- Row 1: 4 cards -->
          <div class="howwe-row4">
