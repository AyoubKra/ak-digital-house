---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/ui/Navigation.astro';
import Footer from '../../components/ui/Footer.astro';
import AdsCampaignTypes from '../../components/sections/AdsCampaignTypes.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title="Paid Ads & Lead Generation | AK Digital House — Raleigh Digital Marketing Agency"
      description="Google Ads, Meta Ads, and LinkedIn Ads management for Raleigh small businesses. Live in 7 business days. Transparent pricing from $750/mo. No contracts."
    />
    <link rel="canonical" href="https://akdigitalhouse.com/services/paid-ads-lead-generation/" />
    <meta property="og:title" content="Stop Paying for Clicks. Start Paying for Customers." />
    <meta property="og:description" content="Google Ads, Meta Ads, and LinkedIn Ads management for Raleigh small businesses. Live in 7 business days. Transparent pricing from $750/mo. No contracts." />
    <meta property="og:url" content="https://akdigitalhouse.com/services/paid-ads-lead-generation/" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Paid Ads & Lead Generation",
      "provider": {
        "@type": "LocalBusiness",
        "name": "AK Digital House",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Raleigh",
          "addressRegion": "NC",
          "addressCountry": "US"
        }
      },
      "areaServed": ["Raleigh","Cary","Durham","Apex","Wake Forest","Morrisville","Chapel Hill","Holly Springs","Fuquay-Varina"],
      "description": "Google Ads, Meta Ads, and LinkedIn Ads management for Raleigh small businesses. Live in 7 business days."
    }
    </script>
  </head>
  <body>
    <Navigation />

    <main>

      <!-- ─── SECTION 1: HERO ─── -->
      <section class="hero-section">
        <div class="hero-inner">
          <!-- Left: Content -->
          <div class="hero-content">
            <span class="hero-label">Paid Ads &amp; Lead Generation</span>
            <h1 class="hero-subheadline">Stop Paying for Clicks. <span class="hero-accent">Start Paying for Customers.</span></h1>
            <p class="hero-desc">
              Raleigh small businesses lose thousands every month to ads that produce traffic but no leads. We build profitable Google and Meta campaigns for the Triangle — live in 7 business days, with the first leads landing in your inbox before most agencies have finished the kickoff call.
            </p>
            <!-- Mobile-only image: shown between desc and buttons on small screens -->
            <div class="hero-image-wrap hero-image-mobile">
              <img src="/PPC.webp" alt="Paid Ads & Lead Generation illustration" class="hero-image" fetchpriority="high" decoding="async" width="420" height="504" />
            </div>
            <div class="hero-buttons">
              <a href="#contact" class="btn-primary">Book a Free Strategy Call →</a>
              <a href="#pricing" class="btn-secondary">See Our Pricing ↓</a>
            </div>
            <!-- Trust badges -->
            <div class="hero-badges">
              <div class="badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Live in 7 Business Days</span>
              </div>
              <div class="badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                <span>30 Days Free Ads Included</span>
              </div>
              <div class="badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span>Cancel Anytime — No Contracts</span>
              </div>
            </div>
          </div>
          <!-- Right: Hero Image (desktop only) -->
          <div class="hero-image-wrap hero-image-desktop">
            <img src="/PPC.webp" alt="Paid Ads & Lead Generation illustration" class="hero-image" fetchpriority="high" decoding="async" width="420" height="504" />
          </div>
        </div>
      </section>

      <!-- ─── SECTION 2: PAIN FRAMING ─── -->
      <section class="ai-section">
        <div class="ai-inner">

          <span class="ai-eyebrow">The Problem</span>
          <h2 class="ai-h2">Most agencies sell you clicks.<br/>You need customers.</h2>
          <p class="ai-intro">You did not start your business to study dashboards at midnight. Most agencies hand you a report full of impressions and CTRs — while your phone stays quiet. Here is what actually happens when a typical agency runs your ads.</p>

          <!-- Comparison infographic -->
          <div class="cmp-table">
            <!-- Header row -->
            <div class="cmp-header cmp-header-left">
              <span>TYPICAL AGENCY</span>
            </div>
            <div class="cmp-header cmp-header-vs"></div>
            <div class="cmp-header cmp-header-right">
              <span>AK DIGITAL HOUSE</span>
            </div>

            <!-- Row 1: Speed -->
            <div class="cmp-cell cmp-cell-left">
              <span class="cmp-x-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
              <p class="cmp-row-text">90-day onboarding before a single ad runs</p>
            </div>
            <div class="cmp-cell cmp-cell-center">
              <div class="cmp-icon-wrap"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            </div>
            <div class="cmp-cell cmp-cell-right">
              <span class="cmp-check-icon">✓</span>
              <p class="cmp-row-text">Campaigns live in 7 business days — or we work for free</p>
            </div>

            <!-- Row 2: Cost -->
            <div class="cmp-cell cmp-cell-left">
              <span class="cmp-x-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
              <p class="cmp-row-text">$5,000 setup fee paid before any results</p>
            </div>
            <div class="cmp-cell cmp-cell-center">
              <div class="cmp-icon-wrap"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
            </div>
            <div class="cmp-cell cmp-cell-right">
              <span class="cmp-check-icon">✓</span>
              <p class="cmp-row-text">No setup fee — flat monthly management only</p>
            </div>

            <!-- Row 3: Reporting -->
            <div class="cmp-cell cmp-cell-left">
              <span class="cmp-x-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
              <p class="cmp-row-text">Reports full of impressions — not leads or revenue</p>
            </div>
            <div class="cmp-cell cmp-cell-center">
              <div class="cmp-icon-wrap"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></div>
            </div>
            <div class="cmp-cell cmp-cell-right">
              <span class="cmp-check-icon">✓</span>
              <p class="cmp-row-text">Weekly plain-English report: cost per lead, what's next</p>
            </div>

            <!-- Row 4: Ownership -->
            <div class="cmp-cell cmp-cell-left">
              <span class="cmp-x-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
              <p class="cmp-row-text">They own your ad accounts — you leave with nothing</p>
            </div>
            <div class="cmp-cell cmp-cell-center">
              <div class="cmp-icon-wrap"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg></div>
            </div>
            <div class="cmp-cell cmp-cell-right">
              <span class="cmp-check-icon">✓</span>
              <p class="cmp-row-text">You own your ad accounts from day one, always</p>
            </div>

            <!-- Row 5: Contract -->
            <div class="cmp-cell cmp-cell-left">
              <span class="cmp-x-icon"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
              <p class="cmp-row-text">Locked into a 12-month contract after month one</p>
            </div>
            <div class="cmp-cell cmp-cell-center">
              <div class="cmp-icon-wrap"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
            </div>
            <div class="cmp-cell cmp-cell-right">
              <span class="cmp-check-icon">✓</span>
              <p class="cmp-row-text">Month-to-month — cancel anytime, no penalty</p>
            </div>
          </div>

          <!-- What we bring to the table -->
          <p class="ai-pivot">What we actually do before spending your budget.</p>

          <div class="ai-boxes">
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Your market</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></div>
              </div>
              <p class="ai-box-sub">We analyze your market, competitors, and opportunities before launching anything.</p>
            </div>
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Buyer intent</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
              </div>
              <p class="ai-box-sub">We focus on high-intent keywords — people already looking for what you offer.</p>
            </div>
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Conversion tracking</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
              </div>
              <p class="ai-box-sub">Every call, form, and click tracked so we know what drives revenue</p>
            </div>
            <div class="ai-box">
              <div class="ai-box-header">
                <p class="ai-box-title">Weekly optimization</p>
                <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg></div>
              </div>
              <p class="ai-box-sub">We cut what’s not working and scale what is, every single week.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ─── SECTION 2B: HOW WE DO IT ─── -->
      <section class="howwe-section">
        <div class="howwe-inner">

          <!-- Top: centered header -->
          <div class="howwe-header">
            <span class="ai-eyebrow">OUR FEATURE</span>
            <h2 class="howwe-h2">Everything Your Campaign Needs. <span class="howwe-accent">Nothing It Doesn't.</span></h2>
            <p class="howwe-intro">We handle every moving part — so you never have to wonder where your budget went or why the phone isn't ringing.</p>
          </div>

          <!-- Row 1: 4 cards -->
          <div class="howwe-row4">
            <div class="howwe-card">
              <div class="howwe-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              </div>
              <p class="howwe-card-label">Campaign Setup</p>
              <p class="howwe-card-sublabel">Before We Go Live</p>
              <p class="howwe-card-desc">Built right before day one — structure, bidding, goals, and zero budget leaks.</p>
            </div>
            <div class="howwe-card">
              <div class="howwe-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              </div>
              <p class="howwe-card-label">Targeting &amp; Research</p>
              <p class="howwe-card-sublabel">Finding Your Buyer</p>
              <p class="howwe-card-desc">We find the people ready to buy — and block everyone else from seeing your ads.</p>
            </div>
            <div class="howwe-card">
              <div class="howwe-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg>
              </div>
              <p class="howwe-card-label">Ad Creatives</p>
              <p class="howwe-card-sublabel">What People Actually See</p>
              <p class="howwe-card-desc">Every headline and call to action written to convert, not just fill the character limit.</p>
            </div>
            <div class="howwe-card">
              <div class="howwe-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              </div>
              <p class="howwe-card-label">Landing Page Guidance</p>
              <p class="howwe-card-sublabel">Where the Click Goes</p>
              <p class="howwe-card-desc">The ad gets the click. We make sure the page gets the lead.</p>
            </div>
          </div>

          <!-- Row 2: offer left + 2 cards right -->
          <div class="howwe-row-bottom">
            <!-- Offer card: bottom left -->
            <div class="howwe-offer">
              <p class="howwe-offer-title">Start risk-free.</p>
              <div class="howwe-offer-item">
                <span class="howwe-offer-tag">Web + Ads</span>
                <span class="howwe-offer-desc">Build your site with us — first 30 days of ads free.</span>
              </div>
              <div class="howwe-offer-item">
                <span class="howwe-offer-tag">Ads Only</span>
                <span class="howwe-offer-desc">Stay 2 months — month 3 is on us.</span>
              </div>
              <a href="#contact" class="howwe-offer-btn">Book a Free Strategy Call →</a>
            </div>

            <div class="howwe-card">
              <div class="howwe-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
              </div>
              <p class="howwe-card-label">Weekly Optimization</p>
              <p class="howwe-card-sublabel">After Launch</p>
              <p class="howwe-card-desc">Every Monday we cut what's not working. Every Friday you get a plain-English update.</p>
            </div>
            <div class="howwe-card">
              <div class="howwe-card-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
              </div>
              <p class="howwe-card-label">Lead Tracking</p>
              <p class="howwe-card-sublabel">Measuring What Matters</p>
              <p class="howwe-card-desc">A live dashboard that answers the only question that matters — is this working?</p>
            </div>
          </div>

        </div>
      </section>

      <!-- ─── SECTION 3: CAMPAIGN TYPES ─── -->
      <AdsCampaignTypes />

      <!-- ─── SECTION 4: HOW IT WORKS ─── -->
      <section class="proc-section">

        <div class="proc-header">
          <span class="proc-eyebrow">How It Works</span>
          <h2 class="proc-h2">Live in 7 Business Days. Here's How.</h2>
        </div>

        <div class="proc-track">

          <!-- S-curve wave connector (desktop only) -->
          <svg class="proc-wave-svg" viewBox="0 0 1100 96" preserveAspectRatio="xMidYMid meet" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M 110 48 C 165 90, 275 90, 330 48 C 385 6, 495 6, 550 48 C 605 90, 715 90, 770 48 C 825 6, 935 6, 990 48" stroke="#d91e45" stroke-width="5" stroke-linecap="round" fill="none"/>
          </svg>

          <div class="proc-steps">

            <!-- 1 -->
            <div class="proc-step">
              <div class="proc-icon-col">
                <div class="proc-circle">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6.08 6.08l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.72 16.92z"/></svg>
                </div>
                <div class="proc-num-badge">Day 1</div>
              </div>
              <div class="proc-text-col">
                <h3 class="proc-title">Strategy Call</h3>
                <p class="proc-body">30 minutes. We map your goals, set the budget, and send you a written plan and fixed monthly fee the same day.</p>
              </div>
            </div>

            <!-- 2 -->
            <div class="proc-step">
              <div class="proc-icon-col">
                <div class="proc-circle">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M8.46 8.46a5 5 0 0 0 0 7.07"/></svg>
                </div>
                <div class="proc-num-badge">Days 2–3</div>
              </div>
              <div class="proc-text-col">
                <h3 class="proc-title">Account Setup</h3>
                <p class="proc-body">Ad accounts, conversion tracking, call tracking, CRM. Landing page built if you need one.</p>
              </div>
            </div>

            <!-- 3 -->
            <div class="proc-step">
              <div class="proc-icon-col">
                <div class="proc-circle">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </div>
                <div class="proc-num-badge">Days 4–5</div>
              </div>
              <div class="proc-text-col">
                <h3 class="proc-title">Creative &amp; Copy</h3>
                <p class="proc-body">We write the ads and build your audiences. One round of edits — you approve, we move.</p>
              </div>
            </div>

            <!-- 4 -->
            <div class="proc-step">
              <div class="proc-icon-col">
                <div class="proc-circle">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
                </div>
                <div class="proc-num-badge">Day 7</div>
              </div>
              <div class="proc-text-col">
                <h3 class="proc-title">Launch</h3>
                <p class="proc-body">Campaigns go live. Dashboard link in your inbox the same day.</p>
              </div>
            </div>

            <!-- 5 -->
            <div class="proc-step">
              <div class="proc-icon-col">
                <div class="proc-circle">
                  <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                </div>
                <div class="proc-num-badge">Every Week</div>
              </div>
              <div class="proc-text-col">
                <h3 class="proc-title">Optimization</h3>
                <p class="proc-body">We cut what isn't working, scale what is. Plain-English report every Friday.</p>
              </div>
            </div>

          </div>
        </div>
      </section>

