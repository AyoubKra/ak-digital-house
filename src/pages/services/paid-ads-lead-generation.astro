---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/ui/Navigation.astro';
import Footer from '../../components/ui/Footer.astro';

const features = [
  { icon: '🎯', title: 'Precision Targeting', desc: 'We reach your exact audience — by industry, job title, location, behavior, and intent.' },
  { icon: '💰', title: 'ROI-Focused', desc: 'Every dollar is tracked. We optimize for leads and revenue, not just clicks.' },
  { icon: '📊', title: 'Full Transparency', desc: 'Monthly reports show exactly what\'s running, what\'s working, and what\'s next.' },
  { icon: '🔄', title: 'Continuous Optimization', desc: 'We test, analyze, and improve campaigns every week to lower your cost per lead.' },
  { icon: '📱', title: 'Multi-Channel', desc: 'Google, Meta, LinkedIn — we run ads where your audience spends their time.' },
  { icon: '🚀', title: 'Fast Results', desc: 'Unlike SEO, paid ads can generate leads within days of launch.' },
];

const channels = [
  { name: 'Google Ads', desc: 'Search, Display, YouTube — capture demand when people are actively looking.' },
  { name: 'Meta Ads', desc: 'Facebook & Instagram campaigns to build awareness and generate leads at scale.' },
  { name: 'LinkedIn Ads', desc: 'Ideal for B2B — target by job title, company size, and industry with precision.' },
  { name: 'Retargeting', desc: 'Re-engage visitors who didn\'t convert the first time with targeted follow-up ads.' },
];

const process = [
  { step: '01', title: 'Audit & Strategy', desc: 'We analyze your current performance, competitors, and audience to build a data-backed plan.' },
  { step: '02', title: 'Campaign Setup', desc: 'We build your campaigns, ad creatives, landing pages, and tracking from scratch.' },
  { step: '03', title: 'Launch & Monitor', desc: 'We launch your campaigns and monitor performance daily in the first weeks.' },
  { step: '04', title: 'Optimize & Scale', desc: 'We cut what doesn\'t work and scale what does — every month, continuously.' },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title="Paid Ads & Lead Generation — AK Digital House"
      description="Data-driven Google, Meta, and LinkedIn ad campaigns that generate qualified leads and real ROI."
    />
  </head>
  <body>
    <Navigation />

    <main>

    <!-- ─── HERO ─── -->
    <section class="hero-section">
      <div class="hero-inner">
        <div class="hero-content">
          <span class="hero-label">Service</span>
          <h1 class="hero-headline">Paid Ads &amp; Lead Generation</h1>
          <h2 class="hero-subheadline">Stop Burning Budget on Ads <span class="hero-accent">That Don't Convert.</span></h2>
          <p class="hero-desc">
            Your competitors are showing up on Google and Meta right now — and some of them are your old leads. We build and manage data-driven ad campaigns for Raleigh businesses that turn ad spend into a predictable pipeline of qualified leads. No wasted clicks. No guesswork. Just results you can measure.
          </p>
          <div class="hero-buttons">
            <a href="#contact" class="btn-primary">Launch My Campaign →</a>
            <a href="#process" class="btn-secondary">See How It Works ↓</a>
          </div>
          <div class="hero-badges">
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
              <span>Precision Targeting</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              <span>ROI-Focused Reporting</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              <span>Campaigns Live in Days</span>
            </div>
          </div>
        </div>
        <div class="hero-image-wrap">
          <img src="/ppc-paid-ads-service.svg" alt="Paid Ads & Lead Generation" class="hero-image" />
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="overview-section">
      <div class="section-inner overview-grid">
        <div class="overview-text">
          <h2>Turn your ad budget into predictable revenue</h2>
          <p>Most businesses waste money on ads because they're targeting the wrong people or sending them to the wrong page. We fix both.</p>
          <p>We build paid campaigns that are laser-targeted to your ideal customer, with landing pages optimized to convert, and reporting that shows you exactly what's working.</p>
        </div>
        <div class="overview-list">
          <h3>What's included</h3>
          <ul>
            <li>Competitor & audience research</li>
            <li>Campaign strategy & planning</li>
            <li>Ad creative (copy + visuals)</li>
            <li>Landing page setup & optimization</li>
            <li>Conversion tracking setup</li>
            <li>Weekly optimization</li>
            <li>Monthly performance reports</li>
            <li>A/B testing</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Channels -->
    <section class="channels-section">
      <div class="section-inner">
        <h2 class="section-title">Ad channels we manage</h2>
        <div class="channels-grid">
          {channels.map(c => (
            <div class="channel-card">
              <h3>{c.name}</h3>
              <p>{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features-section">
      <div class="section-inner">
        <h2 class="section-title">Why our campaigns perform</h2>
        <div class="features-grid">
          {features.map(f => (
            <div class="feature-card">
              <span class="feature-icon">{f.icon}</span>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="process-section">
      <div class="section-inner">
        <h2 class="section-title">Our process</h2>
        <div class="process-grid">
          {process.map(p => (
            <div class="process-card">
              <span class="process-step">{p.step}</span>
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="section-inner cta-inner">
        <h2>Ready to generate more leads?</h2>
        <p>Book a free strategy call and let's build your growth engine.</p>
        <a href="/contact" class="cta-btn">Book a Free Strategy Call</a>
      </div>
    </section>

   <!-- SERVING THE TRIANGLE -->
    <section class="service-area">
      <div class="section-inner">
        <div class="service-area-header">
          <span class="area-label">Service Area</span>
          <h2>Proudly Serving North Carolina</h2>
          <p>Based in Raleigh, we partner with businesses across the entire state of North Carolina — from the Triangle to Charlotte, Wilmington, Asheville, and everywhere in between. Distance is never a barrier to great work.</p>
        </div>

        <div class="nc-coverage">
          <div class="nc-coverage-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D91E45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <p class="nc-item-title">Triangle Area</p>
              <p class="nc-item-sub">In-person visits available within ~30 min of Raleigh</p>
            </div>
          </div>
          <div class="nc-coverage-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D91E45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            <div>
              <p class="nc-item-title">All of North Carolina</p>
              <p class="nc-item-sub">Full digital services remotely — Charlotte, Wilmington, Asheville, Greensboro & more</p>
            </div>
          </div>
          <div class="nc-coverage-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#D91E45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <div>
              <p class="nc-item-title">Nationwide</p>
              <p class="nc-item-sub">We welcome clients from any state — results travel further than we do</p>
            </div>
          </div>
        </div>

        <div class="cities-label">Local Triangle cities we serve:</div>
        <div class="cities-grid">
          {[
            'Raleigh', 'Cary', 'Durham', 'Morrisville',
            'Apex', 'Wake Forest', 'Garner', 'Knightdale',
            'Holly Springs', 'Fuquay-Varina', 'Rolesville', 'Wendell',
            'Zebulon', 'Clayton'
          ].map(city => (
            <div class="city-tag">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="#D91E45"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/></svg>
              {city}
            </div>
          ))}
        </div>
      </div>
    </section>
    
    </main>

    <Footer />
  </body>
</html>

<style>
  body { margin: 0; font-family: "Plus Jakarta Sans", system-ui, sans-serif; color: #242729; background: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }

  /* Hero */
  .hero-section { background: linear-gradient(135deg, #fff 0%, rgba(217,30,69,0.06) 50%, #fff 100%); padding: 88px 24px 80px; overflow: hidden; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; }
  .hero-label { display: inline-block; background: rgba(217,30,69,0.1); color: #d91e45; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 16px; border-radius: 100px; margin-bottom: 24px; }
  .hero-headline { font-size: clamp(0.875rem, 1.2vw, 1rem); font-weight: 700; color: #d91e45; text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 14px; }
  .hero-subheadline { font-size: clamp(1.75rem, 3.5vw, 2.75rem); font-weight: 800; color: #1a1c1e; line-height: 1.2; margin: 0 0 20px; }
  .hero-accent { color: #d91e45; }
  .hero-image { width: 100%; max-width: 520px; height: auto; display: block; }
  .hero-desc { font-size: clamp(0.9375rem, 1.2vw, 1.0625rem); color: #6b7280; line-height: 1.8; margin: 0 0 36px; }
  .hero-buttons { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 36px; }
  .btn-primary { display: inline-flex; align-items: center; background: #d91e45; color: #fff; font-weight: 700; font-size: 0.9375rem; padding: 14px 32px; border-radius: 1000px; text-decoration: none; transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease; }
  .btn-primary:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 10px 24px rgba(217,30,69,0.28); }
  .btn-secondary { display: inline-flex; align-items: center; background: transparent; color: #1a1c1e; font-weight: 700; font-size: 0.9375rem; padding: 14px 32px; border-radius: 1000px; border: 1.5px solid #1a1c1e; text-decoration: none; transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease; }
  .btn-secondary:hover { background: #1a1c1e; color: #fff; transform: translateY(-2px); }
  .hero-badges { display: flex; flex-wrap: wrap; gap: 12px 20px; }
  .badge { display: flex; align-items: center; gap: 7px; font-size: 0.8125rem; font-weight: 600; color: #242729; }
  .hero-image-wrap { display: flex; align-items: center; justify-content: center; }
  .hero-image-placeholder { width: 100%; max-width: 480px; height: 360px; background: rgba(217,30,69,0.05); border: 2px dashed rgba(217,30,69,0.2); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #d91e45; font-size: 0.875rem; font-weight: 600; opacity: 0.6; }
  .hero-image-placeholder::after { content: 'Image coming soon'; }

  .overview-section { padding: 80px 24px; }
  .overview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .overview-text h2 { font-size: clamp(1.5rem, 2vw, 1.75rem); font-weight: 700; color: #1A1C1E; margin: 0 0 20px; line-height: 1.2; }
  .overview-text p { font-size: 0.9375rem; color: #555; line-height: 1.8; margin: 0 0 16px; }
  .overview-list h3 { font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #D91E45; margin: 0 0 16px; }
  .overview-list ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .overview-list li { font-size: 0.9375rem; color: #242729; padding-left: 20px; position: relative; line-height: 1.5; }
  .overview-list li::before { content: '✓'; position: absolute; left: 0; color: #D91E45; font-weight: 700; }

  .channels-section { background: #F9F9F9; padding: 80px 24px; }
  .section-title { font-size: clamp(1.5rem, 2vw, 1.75rem); font-weight: 700; color: #1A1C1E; text-align: center; margin: 0 0 48px; line-height: 1.2; }
  .channels-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .channel-card { background: #fff; border: 1px solid #E0E0E0; border-radius: 12px; padding: 28px 24px; border-top: 3px solid #D91E45; }
  .channel-card h3 { font-size: 1rem; font-weight: 700; color: #1A1C1E; margin: 0 0 10px; }
  .channel-card p { font-size: 0.9375rem; color: #555; line-height: 1.6; margin: 0; }

  .features-section { padding: 80px 24px; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .feature-card { background: #F9F9F9; border: 1px solid #E0E0E0; border-radius: 12px; padding: 28px 24px; display: flex; flex-direction: column; gap: 12px; transition: box-shadow 0.2s ease, transform 0.2s ease; }
  .feature-card:hover { box-shadow: 0 10px 30px rgba(217,30,69,0.1); transform: translateY(-2px); }
  .feature-icon { font-size: 1.75rem; }
  .feature-card h3 { font-size: 1rem; font-weight: 700; color: #1A1C1E; margin: 0; }
  .feature-card p { font-size: 0.9375rem; color: #555; line-height: 1.6; margin: 0; }

  .process-section { background: #F9F9F9; padding: 80px 24px; }
  .process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .process-card { background: #fff; border: 1px solid #E0E0E0; border-radius: 12px; padding: 28px 24px; display: flex; flex-direction: column; gap: 12px; }
  .process-step { font-size: 2rem; font-weight: 700; color: #D91E45; line-height: 1; }
  .process-card h3 { font-size: 1rem; font-weight: 700; color: #1A1C1E; margin: 0; }
  .process-card p { font-size: 0.9375rem; color: #555; line-height: 1.6; margin: 0; }

  .cta-section { background: #1A1C1E; padding: 80px 24px; }
  .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .cta-inner h2 { font-size: clamp(1.5rem, 2.5vw, 1.75rem); font-weight: 700; color: #fff; margin: 0; }
  .cta-inner p { font-size: 1rem; color: rgba(255,255,255,0.65); margin: 0; }
  .cta-btn { display: inline-flex; align-items: center; padding: 16px 32px; background: #D91E45; color: #fff; font-size: 1rem; font-weight: 500; border-radius: 1000px; text-decoration: none; transition: transform 0.2s ease, filter 0.2s ease, box-shadow 0.2s ease; }
  .cta-btn:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(217,30,69,0.25); color: #fff; }

  @media (max-width: 900px) {
    .channels-grid { grid-template-columns: repeat(2, 1fr); }
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .process-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .overview-grid { grid-template-columns: 1fr; gap: 40px; }
    .overview-section, .channels-section, .features-section, .process-section, .cta-section { padding: 48px 16px; }
    .service-hero { padding: 64px 16px 48px; }
  }
  @media (max-width: 560px) {
    .channels-grid { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr; }
    .process-grid { grid-template-columns: 1fr; }
  }
/* ── Service Area ── */
  .service-area {
    background: #F9F9F9;
    padding: 80px 24px;
    border-top: 1px solid #E8E8E8;
  }
  .service-area-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .area-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #D91E45;
    background: rgba(217,30,69,0.08);
    padding: 4px 12px;
    border-radius: 999px;
    margin-bottom: 16px;
  }
  .service-area-header h2 {
    font-size: clamp(1.5rem, 2.5vw, 1.875rem);
    font-weight: 700;
    color: #1A1C1E;
    margin: 0 0 12px;
    line-height: 1.2;
  }
  .service-area-header p {
    font-size: 0.9375rem;
    color: #666;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .cities-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 24px;
  }
  .city-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: #fff;
    border: 1px solid #E0E0E0;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #242729;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .city-tag:hover {
    border-color: #D91E45;
    box-shadow: 0 2px 8px rgba(217,30,69,0.1);
  }
  .cities-label {
    text-align: center;
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #aaa;
    margin: 0 0 14px;
  }

  /* NC Coverage grid */
  .nc-coverage {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 40px;
  }
  .nc-coverage-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    background: #fff;
    border: 1px solid #E8E8E8;
    border-radius: 12px;
    padding: 20px;
  }
  .nc-coverage-item svg { flex-shrink: 0; margin-top: 2px; }
  .nc-item-title { font-size: 0.9375rem; font-weight: 700; color: #1A1C1E; margin: 0 0 4px; }
  .nc-item-sub { font-size: 0.8125rem; color: #666; line-height: 1.5; margin: 0; }

</style>
