  .mq-badge:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }
  .mq-logo {
    height: 32px;
    width: auto;
    display: block;
    filter: grayscale(1);
    transition: filter 0.3s;
  }
  .mq-badge:hover .mq-logo {
    filter: grayscale(0);
  }
  .mq-name {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #6b7280;
    text-align: center;
    white-space: nowrap;
  }

