  .wdmc-list {
    position: relative;
    display: flex;
    flex-direction: column;
    padding-left: 44px;
  }
  .wdmc-list::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 18px;
    bottom: 18px;
    width: 2px;
    background: #e5e7eb;
  }
