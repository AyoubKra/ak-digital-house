  .wdmc-item {
    position: relative;
    display: flex;
    align-items: center;
    padding-bottom: 20px;
  }
  .wdmc-item--last { padding-bottom: 0; }
  /* Spoke: dot + horizontal arm */
  .wdmc-spoke {
    position: absolute;
    left: -44px;
    display: flex;
    align-items: center;
    width: 44px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
