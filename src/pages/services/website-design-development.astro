  /* ── Performance Proof ── */
  @keyframes perf-fill-100 {
    from { stroke-dashoffset: 263.89; }
    to   { stroke-dashoffset: 0; }
  }
  @keyframes perf-fill-96 {
    from { stroke-dashoffset: 263.89; }
    to   { stroke-dashoffset: 10.56; }
  }
  .perf-circles {
    display: flex;
    justify-content: center;
    gap: 48px;
    margin-bottom: 48px;
    flex-wrap: nowrap;
  }
  .perf-circle-wrap { text-align: center; flex-shrink: 0; }
  .perf-svg { width: 148px; height: 148px; }
  .perf-arc--100 {
    animation: perf-fill-100 1.6s cubic-bezier(0.4,0,0.2,1) 0.4s forwards;
  }
  .perf-arc--96 {
    animation: perf-fill-96 1.6s cubic-bezier(0.4,0,0.2,1) 0.4s forwards;
  }
  .perf-metrics {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 16px;
    padding: 28px 40px;
    margin: 0 auto 56px;
    max-width: 900px;
  }
  .perf-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 28px;
    gap: 6px;
  }
  .perf-metric-val {
    font-size: 1.25rem;
    font-weight: 800;
    color: #0cce6b;
    line-height: 1;
  }
  .perf-metric-label {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
    text-align: center;
    line-height: 1.4;
  }
  .perf-metric-divider {
    width: 1px;
    height: 44px;
    background: rgba(255,255,255,0.08);
    flex-shrink: 0;
  }
  .perf-cta-line {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.35);
    line-height: 1.7;
    margin: 0;
  }
  .perf-cta-link {
    color: #0cce6b;
    text-decoration: none;
  }
  .perf-cta-link:hover { text-decoration: underline; }
  .perf-cta-code {
    background: rgba(255,255,255,0.08);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.55);
    word-break: break-all;
  }
  @media (max-width: 640px) {
    .perf-circles { gap: 8px; }
    .perf-svg { width: 92px; height: 92px; }
    .perf-metrics {
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding: 20px 16px;
      gap: 0;
    }
    .perf-metric-divider { display: none; }
    .perf-metric { padding: 14px 8px; }
    .perf-metric-val { font-size: 1.1rem; }
    /* 5th metric (nth-child 9 counting dividers) spans both columns */
    .perf-metrics .perf-metric:nth-child(9) { grid-column: 1 / -1; }
    /* row borders */
    .perf-metrics .perf-metric:nth-child(1),
    .perf-metrics .perf-metric:nth-child(3),
    .perf-metrics .perf-metric:nth-child(5),
    .perf-metrics .perf-metric:nth-child(7) {
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    /* right border on left cells */
    .perf-metrics .perf-metric:nth-child(1),
    .perf-metrics .perf-metric:nth-child(5) {
      border-right: 1px solid rgba(255,255,255,0.06);
