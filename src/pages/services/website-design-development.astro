  /* Marquee outer: clips overflow, holds fades */
  .mq-outer {
    position: relative;
    overflow: hidden;
  }
  .mq-fade-l,
  .mq-fade-r {
    position: absolute;
    top: 0;
    height: 100%;
    width: 96px;
    z-index: 10;
    pointer-events: none;
  }
  .mq-fade-l {
    left: 0;
    background: linear-gradient(to right, #F9F9F9, transparent);
  }
  .mq-fade-r {
    right: 0;
    background: linear-gradient(to left, #F9F9F9, transparent);
  }

  /* Scrolling track */
  .mq-track {
    display: flex;
    width: max-content;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }
  .mq-left  { animation-name: mq-scroll-left; }
  .mq-right { animation-name: mq-scroll-right; }
  .mq-35 { animation-duration: 35s; }
  .mq-40 { animation-duration: 40s; }
  .mq-45 { animation-duration: 45s; }
  .mq-outer:hover .mq-track { animation-play-state: paused; }

  /* Each logo badge */
  .mq-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 16px 24px;
    margin: 0 10px;
    flex-shrink: 0;
    transition: box-shadow 0.3s, transform 0.3s;
