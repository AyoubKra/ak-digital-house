  #faqtab3:checked ~ .faq-grid .faq-panels #faqpanel3,
  #faqtab4:checked ~ .faq-grid .faq-panels #faqpanel4,
  #faqtab5:checked ~ .faq-grid .faq-panels #faqpanel5,
  #faqtab6:checked ~ .faq-grid .faq-panels #faqpanel6 { display: block; }
  /* Accordion items */
  .faq-item {
    border-bottom: 1px solid #f0f0f0;
  }
  .faq-item:first-child { border-top: 1px solid #f0f0f0; }
  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 22px 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1c1e;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: color 0.18s;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item[open] > summary { color: #d91e45; }
  .faq-icon {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1.5px solid #d1d5db;
    position: relative;
    transition: background 0.18s, border-color 0.18s, transform 0.25s;
  }
  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: #9ca3af;
    border-radius: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: background 0.18s;
  }
  .faq-icon::before { width: 10px; height: 2px; }
  .faq-icon::after  { width: 2px; height: 10px; }
  .faq-item[open] > summary .faq-icon {
    background: #d91e45;
    border-color: #d91e45;
    transform: rotate(45deg);
  }
  .faq-item[open] > summary .faq-icon::before,
  .faq-item[open] > summary .faq-icon::after {
    background: #fff;
  }
  .faq-answer {
