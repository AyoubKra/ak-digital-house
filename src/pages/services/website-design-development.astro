---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/ui/Navigation.astro';
import Footer from '../../components/ui/Footer.astro';

---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title="Web Design & Development — AK Digital House | Raleigh, NC"
      description="Custom website design built to convert. AK Digital House creates fast, mobile-first, SEO-ready websites for growing businesses in Raleigh and across North Carolina."
    />
    <!-- JSON-LD: Service + LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "name": "Web Design & Development",
          "description": "Custom, conversion-focused website design and development for growing businesses. Includes mobile-first design, performance optimization, SEO-ready structure, and ongoing maintenance.",
          "provider": {
            "@type": "LocalBusiness",
            "name": "AK Digital House LLC",
            "url": "https://www.akdigitalhouse.com",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Raleigh",
              "addressRegion": "NC",
              "addressCountry": "US"
            },
            "email": "contact@akdigitalhouse.com"
          },
          "areaServed": [
            {"@type":"City","name":"Raleigh"},
            {"@type":"City","name":"Cary"},
            {"@type":"City","name":"Durham"},
            {"@type":"City","name":"Apex"},
            {"@type":"City","name":"Wake Forest"},
            {"@type":"City","name":"Morrisville"},
            {"@type":"City","name":"Chapel Hill"},
            {"@type":"City","name":"Holly Springs"},
            {"@type":"City","name":"Fuquay-Varina"}
          ],
          "url": "https://akdigitalhouse.com/services/website-design-development/"
        },
        {
          "@type": "LocalBusiness",
          "name": "AK Digital House LLC",
          "url": "https://www.akdigitalhouse.com",
          "logo": "https://www.akdigitalhouse.com/logo-color.png",
          "image": "https://www.akdigitalhouse.com/logo-color.png",
          "description": "Full-service digital marketing agency specializing in web design, SEO, paid ads, and branding for growing businesses.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Raleigh",
            "addressRegion": "NC",
            "addressCountry": "US"
          },
          "email": "contact@akdigitalhouse.com",
          "sameAs": [
            "https://www.instagram.com/akdigitalhouse/",
            "https://www.facebook.com/AKDigitalhousellc",
            "https://www.linkedin.com/company/ak-digital-house"
          ]
        }
      ]
    }
    </script>
    <link rel="preload" as="image" href="/Web-Design-Development-pic-opt.webp" fetchpriority="high" />
  </head>

  <body style="margin:0; font-family:'Plus Jakarta Sans',system-ui,sans-serif; color:#242729; background:#fff;">
    <Navigation />

    <main>

    <!-- ─── 1. HERO ─── -->
    <section class="hero-section">
      <div class="hero-inner">
        <!-- Left: Content -->
        <div class="hero-content">
          <span class="hero-label">Web Design &amp; Development</span>
          <h1 class="hero-subheadline">Your Website Should Be Making You Money. <span class="hero-accent">Is It?</span></h1>
          <p class="hero-desc">
            Your next customer just landed on your website, waited 6 seconds for it to load, and left. Right now, they're booking your competitor in Raleigh, Cary, Durham, or Apex. We build fast, conversion-ready websites for small businesses across the Triangle — live in 3 weeks, guaranteed.
          </p>
          <!-- Mobile-only image: shown between desc and buttons on small screens -->
          <div class="hero-image-wrap hero-image-mobile">
            <img src="/Web-Design-Development-pic-opt.webp" alt="Web Design & Development" class="hero-image" fetchpriority="high" decoding="async" width="420" height="504" />
          </div>
          <div class="hero-buttons">
            <a href="#contact" class="btn-primary">Launch My Website →</a>
            <a href="#services" class="btn-secondary">View Pricing ↓</a>
          </div>
          <!-- Trust badges -->
          <div class="hero-badges">
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Launched in 3 Weeks</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
              <span>95+ Lighthouse Score</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polygon points="12 13.5 12.9 15.4 15 15.73 13.5 17.2 13.82 19.3 12 18.27 10.18 19.3 10.5 17.2 9 15.73 11.1 15.4 12 13.5"/></svg>
              <span>1 Year Free Maintenance</span>
            </div>
          </div>
        </div>
        <!-- Right: Hero Image (desktop only) -->
        <div class="hero-image-wrap hero-image-desktop">
          <img src="/Web-Design-Development-pic-opt.webp" alt="Web Design & Development" class="hero-image" fetchpriority="high" decoding="async" width="420" height="504" />
        </div>
      </div>
    </section>

    <!-- ─── AI OBJECTION SECTION ─── -->
    <section class="ai-section">
      <div class="ai-inner">

        <span class="ai-eyebrow">The 2026 Question</span>
        <h2 class="ai-h2">AI generates websites.<br/>We generate customers.</h2>
        <p class="ai-intro">Wix. Squarespace. Framer. Every one of them delivers a website that looks like a thousand others — written by an algorithm that has never spoken to your customers, studied your competitors, or understood your market. The tool builds the page. Nobody builds the argument.</p>

        <!-- Comparison boxes -->
        <div class="ai-vs-wrap">
          <div class="ai-vs-box ai-vs-box-left">
            <p class="ai-vs-label">AI WEBSITE BUILDER</p>
            <ul class="ai-vs-list">
              <li><span class="ai-x">✕</span>Generic copy written for no one in particular</li>
              <li><span class="ai-x">✕</span>Templates shared across millions of sites</li>
              <li><span class="ai-x">✕</span>No conversion architecture — CTAs placed by default</li>
              <li><span class="ai-x">✕</span>Zero local SEO — optimizes for nothing</li>
              <li><span class="ai-x">✕</span>Delivers a file. Nobody watches what happens next.</li>
            </ul>
          </div>
          <div class="ai-vs-box ai-vs-box-right">
            <p class="ai-vs-label ai-vs-label-red">AK DIGITAL HOUSE</p>
            <ul class="ai-vs-list">
              <li><span class="ai-check">✓</span>Copy built on your market, your buyer, your competitors</li>
              <li><span class="ai-check">✓</span>Custom build — looks like no one else in the Triangle</li>
              <li><span class="ai-check">✓</span>Every CTA placed where buyers actually make decisions</li>
              <li><span class="ai-check">✓</span>Local SEO and schema built in from line one of code</li>
              <li><span class="ai-check">✓</span>12 months free maintenance — we watch it like it's ours</li>
            </ul>
          </div>
        </div>

        <!-- We use AI too -->
        <p class="ai-pivot">We use AI too — extensively.</p>

        <div class="ai-boxes">
          <div class="ai-box">
            <div class="ai-box-header">
              <p class="ai-box-title">Your market</p>
              <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></div>
            </div>
            <p class="ai-box-sub">We research before AI touches anything</p>
          </div>
          <div class="ai-box">
            <div class="ai-box-header">
              <p class="ai-box-title">Buyer psychology</p>
              <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
            </div>
            <p class="ai-box-sub">How your customer decides — not how templates assume</p>
          </div>
          <div class="ai-box">
            <div class="ai-box-header">
              <p class="ai-box-title">Competitive gap</p>
              <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
            </div>
            <p class="ai-box-sub">What your competitors miss — and how to own it</p>
          </div>
          <div class="ai-box">
            <div class="ai-box-header">
              <p class="ai-box-title">Conversion goal</p>
              <div class="ai-box-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
            </div>
            <p class="ai-box-sub">Every page built around one outcome, not a template</p>
          </div>
        </div>

        <p class="ai-close">AI executes the strategy. We build the strategy. That's the part no $16/month tool replaces.</p>

      </div>
    </section>

    <!-- ─── 2. OUR COMMITMENTS ─── -->
    <section class="wdmc-section">
      <!-- Top: centered eyebrow + heading + description -->
      <div class="wdmc-header">
        <span class="wdmc-eyebrow">Our Commitments</span>
        <h2 class="wdmc-h2">We Don't Just Promise Results. We Put Them in Writing.</h2>
        <p class="wdmc-sub">Every project we take on comes with a set of non-negotiable standards. Not because we have to — because that's the only way we work.</p>
      </div>

      <div class="wdmc-inner">

        <!-- Left: image -->
        <div class="wdmc-img-col">
          <div class="wdmc-img-wrap">
            <img
              src="/business-deal-commitments.svg"
              alt="AK Digital House web design team"
              class="wdmc-img"
            />
          </div>
        </div>

        <!-- Right: spoke items only -->
        <div class="wdmc-content">
          <div class="wdmc-list">

            <!-- 1 — Timer -->
            <div class="wdmc-item">
              <div class="wdmc-spoke">
                <div class="wdmc-dot"></div>
                <div class="wdmc-spoke-line"></div>
              </div>
              <div class="wdmc-card">
                <div class="wdmc-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 2h4"/><path d="M12 14v-4"/><circle cx="12" cy="14" r="8"/><path d="m15 11-1 1"/></svg>
                </div>
                <div class="wdmc-text">
                  <h3 class="wdmc-title">Launched in 3 Weeks or Less</h3>
                  <p class="wdmc-body">In the rare event we miss the 21-day delivery window due to our delay, we’ll apply a 10% credit to your final invoice. This timeline assumes timely client feedback (within 48 hours) and no changes to the agreed scope.</p>
                </div>
              </div>
            </div>

            <!-- 2 — Zap -->
            <div class="wdmc-item">
              <div class="wdmc-spoke">
                <div class="wdmc-dot"></div>
                <div class="wdmc-spoke-line"></div>
              </div>
              <div class="wdmc-card">
                <div class="wdmc-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </div>
                <div class="wdmc-text">
                  <h3 class="wdmc-title">Loads Under 2 Seconds</h3>
                  <p class="wdmc-body">Every website we build is engineered for speed from the first line of code. Fast enough to keep every visitor, fast enough to rank on Google.</p>
                </div>
              </div>
            </div>

            <!-- 3 — ShieldCheck -->
            <div class="wdmc-item">
              <div class="wdmc-spoke">
                <div class="wdmc-dot"></div>
                <div class="wdmc-spoke-line"></div>
              </div>
              <div class="wdmc-card">
                <div class="wdmc-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                </div>
                <div class="wdmc-text">
                  <h3 class="wdmc-title">1 Year of Free Maintenance</h3>
                  <p class="wdmc-body">Security updates, performance monitoring, and small content edits included for 12 months after launch.</p>
                </div>
              </div>
            </div>

            <!-- 4 — Gauge -->
            <div class="wdmc-item">
              <div class="wdmc-spoke">
                <div class="wdmc-dot"></div>
                <div class="wdmc-spoke-line"></div>
              </div>
              <div class="wdmc-card">
                <div class="wdmc-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 14 4-4"/><path d="M3.34 19a10 10 0 1 1 17.32 0"/></svg>
                </div>
                <div class="wdmc-text">
                  <h3 class="wdmc-title">95+ Google Lighthouse Score</h3>
                  <p class="wdmc-body">We deliver every site with a 95+ Lighthouse score — or we keep optimizing it for free until it meets the standard.</p>
                </div>
              </div>
            </div>

            <!-- 5 — Handshake -->
            <div class="wdmc-item wdmc-item--last">
              <div class="wdmc-spoke">
                <div class="wdmc-dot"></div>
                <div class="wdmc-spoke-line"></div>
              </div>
              <div class="wdmc-card">
                <div class="wdmc-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/></svg>
                </div>
                <div class="wdmc-text">
                  <h3 class="wdmc-title">No Surprises, Ever</h3>
                  <p class="wdmc-body">Clear pricing before we start, structured payments in three stages, and full transparency throughout. You always know where your project stands.</p>
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </section>

    <!-- ─── 2. SUB-SERVICES ─── -->
    <section id="services" class="sub-services-section">
      <div class="sub-services-inner">

        <div class="sub-services-header">
          <span style="display:inline-block; background:rgba(217,30,69,0.1); color:#d91e45; font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:6px 16px; border-radius:100px; margin-bottom:16px;">What We Build</span>
          <h2 class="sub-h2">One Website Type Won't Fit Every Goal. We Build the Right One for Yours.</h2>
          <p class="sub-subtext">Whether you need a campaign page that converts, a store that sells, or a brand presence that ranks — we scope the build around the outcome, not a template.</p>
          <p class="sub-subtext">We're currently building our portfolio, so pricing is lower than it will be long-term. Early clients lock in these rates.</p>
        </div>

        <div class="sub-grid">

          <!-- Card 1 — Landing Pages -->
          <div class="sub-card">
            <div class="sub-card-top">
              <span class="sub-card-price">Starting from <strong>$1,500</strong></span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <h3 class="sub-card-title">High-Converting Landing Pages</h3>
            <p class="sub-card-tagline">Turn Ad Spend Into Booked Clients</p>
            <p class="sub-card-desc"> One page. One goal. More clients. We build fast, focused landing pages that turn your ad traffic into phone calls, form fills, and booked appointments, nothing else gets in the way.</p>            <ul class="sub-card-features">
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>One page, one goal</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">no distractions, just conversions</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Loads in under 2 seconds</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">fast enough to keep every visitor</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Mobile-perfect on any screen</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">phones, tablets, desktops</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Instant lead notifications</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">know the second someone reaches out</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Ad-ready from day one</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">Google, Meta, and TikTok plug straight in</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Tracks every click and sale</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">full visibility on what's working</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Built-in contact and booking forms</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">no third-party tools needed</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>SEO-optimized from the ground up</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">ranks even without <a href="/services/paid-ads-lead-generation" class="inline-service-link">paid ads</a></small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Update anything yourself</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">no developer needed for changes</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Designed to build trust fast</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">social proof, guarantees, and CTAs in the right places</small></span></li>
            </ul>
            <div class="sub-card-divider"></div>
            <a href="#contact" class="sub-card-cta">Start Generating Leads <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>

          <!-- Card 2 — E-Commerce -->
          <div class="sub-card">
            <div class="sub-card-top">
              <span class="sub-card-price">Starting from <strong>$3,500</strong></span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></svg>
            </div>
            <h3 class="sub-card-title">Results-Driven E-Commerce</h3>
            <p class="sub-card-tagline">Your Online Store, Built to Sell</p>
