---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/ui/Navigation.astro';
import Footer from '../../components/ui/Footer.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title="Web Design — AK Digital House | Raleigh, NC"
      description="Custom web design built to convert. AK Digital House creates fast, mobile-first, SEO-ready websites for growing businesses in Raleigh and across North Carolina."
    />
    <link rel="canonical" href="https://www.akdigitalhouse.com/services/web-design" />
  </head>

  <body style="margin:0; font-family:'Plus Jakarta Sans',system-ui,sans-serif; color:#242729; background:#fff;">
    <Navigation />

    <!-- ─── OUR COMMITMENTS ─── -->
    <section class="commitments-section">
      <div class="commitments-inner">

        <!-- Left column: image -->
        <div class="commitments-image-col">
          <div class="commitments-image-wrap">
            <img
              src="/business-deal-commitments.svg"
              alt="AK Digital House web design team"
              class="commitments-image"
            />
          </div>
        </div>

        <!-- Right column: text + items -->
        <div class="commitments-content-col">
          <span class="commitments-eyebrow">Our Commitments</span>
          <h2 class="commitments-h2">We Don't Just Promise Results. We Put Them in Writing.</h2>
          <p class="commitments-subtext">Every project we take on comes with a set of non-negotiable standards. Not because we have to — because that's the only way we work.</p>

          <div class="commitments-list">

            <!-- 1. Timer -->
            <div class="commitment-item">
              <div class="commitment-line-col">
                <div class="commitment-dot"></div>
                <div class="commitment-line"></div>
              </div>
              <div class="commitment-icon-wrap">
                <!-- Timer icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 2h4"/><path d="M12 14v-4"/><circle cx="12" cy="14" r="8"/>
                  <path d="m15 11-1 1"/>
                </svg>
              </div>
              <div class="commitment-text">
                <h3 class="commitment-title">Launched in 3 Weeks or Less</h3>
                <p class="commitment-body">From strategy call to live website in 21 days or less — guaranteed from the moment the contract is signed.</p>
              </div>
            </div>

            <!-- 2. Zap -->
            <div class="commitment-item">
              <div class="commitment-line-col">
                <div class="commitment-dot"></div>
                <div class="commitment-line"></div>
              </div>
              <div class="commitment-icon-wrap">
                <!-- Zap icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              </div>
              <div class="commitment-text">
                <h3 class="commitment-title">Loads Under 2 Seconds</h3>
                <p class="commitment-body">Every website we build is engineered for speed from the first line of code. Fast enough to keep every visitor, fast enough to rank on Google.</p>
              </div>
            </div>

            <!-- 3. ShieldCheck -->
            <div class="commitment-item">
              <div class="commitment-line-col">
                <div class="commitment-dot"></div>
                <div class="commitment-line"></div>
              </div>
              <div class="commitment-icon-wrap">
                <!-- ShieldCheck icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <polyline points="9 12 11 14 15 10"/>
                </svg>
              </div>
              <div class="commitment-text">
                <h3 class="commitment-title">1 Year of Free Maintenance</h3>
                <p class="commitment-body">Security updates, performance monitoring, and small content edits included for 12 months after launch.</p>
              </div>
            </div>

            <!-- 4. Gauge -->
            <div class="commitment-item">
              <div class="commitment-line-col">
                <div class="commitment-dot"></div>
                <div class="commitment-line"></div>
              </div>
              <div class="commitment-icon-wrap">
                <!-- Gauge icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m12 14 4-4"/>
                  <path d="M3.34 19a10 10 0 1 1 17.32 0"/>
                </svg>
              </div>
              <div class="commitment-text">
                <h3 class="commitment-title">95+ Google Lighthouse Score</h3>
                <p class="commitment-body">Every custom static site and landing page scores 95 or higher on Google Lighthouse. Verified before handover, no exceptions.</p>
              </div>
            </div>

            <!-- 5. Handshake -->
            <div class="commitment-item commitment-item--last">
              <div class="commitment-line-col">
                <div class="commitment-dot"></div>
              </div>
              <div class="commitment-icon-wrap">
                <!-- Handshake icon -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m11 17 2 2a1 1 0 1 0 3-3"/>
                  <path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/>
                  <path d="m21 3 1 11h-2"/>
                  <path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/>
                  <path d="M3 4h8"/>
                </svg>
              </div>
              <div class="commitment-text">
                <h3 class="commitment-title">No Surprises, Ever</h3>
                <p class="commitment-body">Clear pricing before we start, structured payments in three stages, and full transparency throughout. You always know where your project stands.</p>
              </div>
            </div>

          </div>
        </div>

      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* ── Commitments section ── */
  .commitments-section {
    background: #ffffff;
    padding: 96px 24px;
  }
  .commitments-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  /* Left: image */
  .commitments-image-col {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .commitments-image-wrap {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.12);
    background: #f9f9f9;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .commitments-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Right: content */
  .commitments-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #d91e45;
    margin-bottom: 16px;
  }
  .commitments-h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: #1a1c1e;
    line-height: 1.25;
    margin: 0 0 16px;
  }
  .commitments-subtext {
    font-size: 0.9375rem;
    color: #6b7280;
    line-height: 1.75;
    margin: 0 0 48px;
  }

  /* List */
  .commitments-list {
    display: flex;
    flex-direction: column;
  }

  /* Each row */
  .commitment-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding-bottom: 28px;
  }
  .commitment-item--last {
    padding-bottom: 0;
  }

  /* Vertical dashed line column */
  .commitment-line-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 16px;
    padding-top: 10px;
  }
  .commitment-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #d91e45;
    flex-shrink: 0;
    z-index: 1;
  }
  .commitment-line {
    width: 2px;
    flex-grow: 1;
    min-height: 28px;
    border-left: 2px dashed #e5e7eb;
    margin-top: 6px;
  }

  /* Icon box */
  .commitment-icon-wrap {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: #d91e45;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0;
  }

  /* Text */
  .commitment-text {
    padding-top: 4px;
  }
  .commitment-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1c1e;
    margin: 0 0 6px;
    line-height: 1.3;
  }
  .commitment-body {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.75;
    margin: 0;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .commitments-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .commitments-image-col {
      display: none;
    }
    .commitments-section {
      padding: 64px 24px;
    }
  }
  @media (max-width: 600px) {
    .commitments-section {
      padding: 48px 20px;
    }
    .commitments-h2 {
      font-size: 1.375rem;
    }
  }
</style>
