---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/ui/Navigation.astro';
import Footer from '../../components/ui/Footer.astro';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title="Website Design & Development — AK Digital House | Raleigh, NC"
      description="Custom website design built to convert. AK Digital House creates fast, mobile-first, SEO-ready websites for growing businesses in Raleigh and across North Carolina."
    />
    <link rel="canonical" href="https://www.akdigitalhouse.com/services/website-design-maintenance" />

    <!-- JSON-LD: Service + LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "name": "Website Design & Maintenance",
          "description": "Custom, conversion-focused website design and development for growing businesses. Includes mobile-first design, performance optimization, SEO-ready structure, and ongoing maintenance.",
          "provider": {
            "@type": "LocalBusiness",
            "name": "AK Digital House LLC",
            "url": "https://www.akdigitalhouse.com",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Raleigh",
              "addressRegion": "NC",
              "addressCountry": "US"
            },
            "email": "contact@akdigitalhouse.com"
          },
          "areaServed": {
            "@type": "State",
            "name": "North Carolina"
          },
          "url": "https://www.akdigitalhouse.com/services/website-design-maintenance"
        },
        {
          "@type": "LocalBusiness",
          "name": "AK Digital House LLC",
          "url": "https://www.akdigitalhouse.com",
          "logo": "https://www.akdigitalhouse.com/logo-color.png",
          "image": "https://www.akdigitalhouse.com/logo-color.png",
          "description": "Full-service digital marketing agency specializing in web design, SEO, paid ads, and branding for growing businesses.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Raleigh",
            "addressRegion": "NC",
            "addressCountry": "US"
          },
          "email": "contact@akdigitalhouse.com",
          "sameAs": [
            "https://www.instagram.com/akdigitalhouse/",
            "https://www.facebook.com/AKDigitalhousellc",
            "https://www.linkedin.com/company/ak-digital-house"
          ]
        }
      ]
    }
    </script>
  </head>

  <body style="margin:0; font-family:'Plus Jakarta Sans',system-ui,sans-serif; color:#242729; background:#fff;">
    <Navigation />

    <!-- ─── 1. HERO ─── -->
    <section class="hero-section">
      <div class="hero-inner">
        <!-- Left: Content -->
        <div class="hero-content">
          <span class="hero-label">Service</span>
          <h1 class="hero-headline">Web Design &amp; Development</h1>
          <h2 class="hero-subheadline">Your Website Should Be Making You Money. <span class="hero-accent">Is It?</span></h2>
          <p class="hero-desc">
            Your next customer just landed on your website, waited 6 seconds for it to load, and left. Right now, that same customer is booking your competitor. We build fast, conversion-ready websites for Raleigh small businesses and startups — live in 3 weeks or less, built to turn every visitor into a long-term paying client.
          </p>
          <div class="hero-buttons">
            <a href="#contact" class="btn-primary">Launch My Website →</a>
            <a href="#packages" class="btn-secondary">See How It Works ↓</a>
          </div>
          <!-- Trust badges -->
          <div class="hero-badges">
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              <span>1 Year Free Maintenance</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              <span>Loads Under 2 Seconds</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M12 14v4"/><path d="M9 18h6"/><path d="M8 6l-1-1M16 6l1-1M6 11H4M20 11h-2"/></svg>
              <span>Affordable Pricing</span>
            </div>
          </div>
        </div>
        <!-- Right: Image -->
        <div class="hero-image-wrap">
          <img src="/Website design and development service.svg" alt="Web Design & Development" class="hero-image" />
        </div>
      </div>
    </section>

    <!-- ─── 2. SOCIAL PROOF BAR ─── -->
    <section style="background:#f8f8f8; border-top:1px solid #e5e7eb; border-bottom:1px solid #e5e7eb; padding:28px 24px;">
      <div style="max-width:1100px; margin:0 auto; display:flex; flex-wrap:wrap; align-items:center; justify-content:center; gap:32px 56px;">
        <div style="text-align:center;">
          <p style="font-size:1.625rem; font-weight:800; color:#1a1c1e; margin:0 0 2px;">100%</p>
          <p style="font-size:0.8125rem; color:#6b7280; margin:0;">Mobile-First Builds</p>
        </div>
        <div style="text-align:center;">
          <p style="font-size:1.625rem; font-weight:800; color:#1a1c1e; margin:0 0 2px;">&lt; 2s</p>
          <p style="font-size:0.8125rem; color:#6b7280; margin:0;">Avg. Load Time</p>
        </div>
        <div style="text-align:center;">
          <p style="font-size:1.625rem; font-weight:800; color:#1a1c1e; margin:0 0 2px;">5-Star</p>
          <p style="font-size:0.8125rem; color:#6b7280; margin:0;">Client Satisfaction</p>
        </div>
        <div style="text-align:center;">
          <p style="font-size:1.625rem; font-weight:800; color:#1a1c1e; margin:0 0 2px;">NC-Based</p>
          <p style="font-size:0.8125rem; color:#6b7280; margin:0;">Raleigh, North Carolina</p>
        </div>
        <div style="text-align:center;">
          <p style="font-size:1.625rem; font-weight:800; color:#1a1c1e; margin:0 0 2px;">90+</p>
          <p style="font-size:0.8125rem; color:#6b7280; margin:0;">PageSpeed Score</p>
        </div>
      </div>
    </section>

    <!-- ─── 3. PROBLEM / SOLUTION ─── -->
    <section style="padding:88px 24px;">
      <div style="max-width:1100px; margin:0 auto;">
        <div class="two-col-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:start;">
          <!-- Problem -->
          <div>
            <span style="display:inline-block; background:#fff0f3; color:#d91e45; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:5px 14px; border-radius:100px; margin-bottom:20px;">The Problem</span>
            <h2 style="font-size:clamp(1.5rem,2.5vw,2rem); font-weight:800; color:#1a1c1e; line-height:1.25; margin:0 0 24px;">
              Most business websites are silent salespeople who never close
            </h2>
            <div style="display:flex; flex-direction:column; gap:16px;">
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">Looks decent but has zero clear call-to-action — visitors leave without contacting you</p>
              </div>
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">Loads slowly on mobile and gets penalized by Google before anyone even sees it</p>
              </div>
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">Built on a template that looks identical to your competitors — no differentiation</p>
              </div>
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">Costs a fortune to update because the agency holds your content hostage</p>
              </div>
            </div>
          </div>
          <!-- Solution -->
          <div>
            <span style="display:inline-block; background:#eafaf1; color:#16a34a; font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:5px 14px; border-radius:100px; margin-bottom:20px;">Our Approach</span>
            <h2 style="font-size:clamp(1.5rem,2.5vw,2rem); font-weight:800; color:#1a1c1e; line-height:1.25; margin:0 0 24px;">
              We build websites engineered to convert, not just impress
            </h2>
            <div style="display:flex; flex-direction:column; gap:16px;">
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">Every page has a clear goal and a conversion path — no dead ends</p>
              </div>
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">Mobile-first, Core Web Vitals–optimized, loading under 2 seconds</p>
              </div>
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">Custom designed around your brand — nothing generic, nothing cookie-cutter</p>
              </div>
              <div style="display:flex; gap:14px; align-items:flex-start;">
                <span style="flex-shrink:0; width:20px; height:20px; margin-top:3px;">
                  <svg viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <p style="font-size:0.9375rem; color:#6b7280; line-height:1.7; margin:0;">You own everything — full access, no lock-in, no hostage fees</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── 4. SERVICE PACKAGES (NO PRICES) ─── -->
    <section id="packages" style="background:#f8f8f8; padding:88px 24px;">
      <div style="max-width:1100px; margin:0 auto;">
        <div style="text-align:center; margin-bottom:56px;">
          <span style="display:inline-block; background:rgba(217,30,69,0.1); color:#d91e45; font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:6px 16px; border-radius:100px; margin-bottom:16px;">What We Offer</span>
          <h2 style="font-size:clamp(1.75rem,3vw,2.25rem); font-weight:800; color:#1a1c1e; margin:0 0 16px;">Website Design Packages</h2>
          <p style="font-size:0.9375rem; color:#6b7280; max-width:540px; margin:0 auto; line-height:1.75;">Every project is scoped to your specific goals. Contact us to discuss which option fits your business.</p>
        </div>
        <div class="pkg-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">

          <!-- Starter -->
          <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:36px 28px; display:flex; flex-direction:column;">
            <div style="width:48px; height:48px; background:#fff0f3; border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:20px; flex-shrink:0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <h3 style="font-size:1.125rem; font-weight:700; color:#1a1c1e; margin:0 0 8px;">Starter Site</h3>
            <p style="font-size:0.875rem; color:#6b7280; line-height:1.7; margin:0 0 24px; flex-grow:1;">Perfect for new businesses or simple online presences that need to look professional and generate leads.</p>
            <ul style="list-style:none; padding:0; margin:0 0 28px; display:flex; flex-direction:column; gap:10px;">
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Up to 5 pages</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Mobile-first responsive design</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Contact form integration</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Basic on-page SEO setup</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>SSL &amp; hosting launch support</li>
            </ul>
            <a href="#contact" style="display:block; text-align:center; background:#f8f8f8; color:#1a1c1e; font-weight:700; font-size:0.875rem; padding:12px 24px; border-radius:8px; text-decoration:none; border:1px solid #e5e7eb;">Get a Quote</a>
          </div>

          <!-- Growth (Featured) -->
          <div style="background:#1a1c1e; border:2px solid #d91e45; border-radius:12px; padding:36px 28px; display:flex; flex-direction:column; position:relative;">
            <span style="position:absolute; top:-13px; left:50%; transform:translateX(-50%); background:#d91e45; color:#fff; font-size:0.6875rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:4px 14px; border-radius:100px; white-space:nowrap;">Most Popular</span>
            <div style="width:48px; height:48px; background:rgba(217,30,69,0.15); border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:20px; flex-shrink:0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
            </div>
            <h3 style="font-size:1.125rem; font-weight:700; color:#fff; margin:0 0 8px;">Growth Site</h3>
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.55); line-height:1.7; margin:0 0 24px; flex-grow:1;">For established businesses ready to invest in a website that actively drives leads and supports growth goals.</p>
            <ul style="list-style:none; padding:0; margin:0 0 28px; display:flex; flex-direction:column; gap:10px;">
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:rgba(255,255,255,0.85);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Up to 10 pages</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:rgba(255,255,255,0.85);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Custom brand-aligned design system</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:rgba(255,255,255,0.85);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Advanced SEO &amp; schema markup</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:rgba(255,255,255,0.85);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>CMS integration (blog / case studies)</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:rgba(255,255,255,0.85);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Analytics &amp; conversion tracking</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:rgba(255,255,255,0.85);"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>30-day post-launch support</li>
            </ul>
            <a href="#contact" style="display:block; text-align:center; background:#d91e45; color:#fff; font-weight:700; font-size:0.875rem; padding:12px 24px; border-radius:8px; text-decoration:none;">Get a Quote</a>
          </div>

          <!-- Authority -->
          <div style="background:#fff; border:1px solid #e5e7eb; border-radius:12px; padding:36px 28px; display:flex; flex-direction:column;">
            <div style="width:48px; height:48px; background:#fff0f3; border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:20px; flex-shrink:0;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            </div>
            <h3 style="font-size:1.125rem; font-weight:700; color:#1a1c1e; margin:0 0 8px;">Authority Site</h3>
            <p style="font-size:0.875rem; color:#6b7280; line-height:1.7; margin:0 0 24px; flex-grow:1;">For brands that want to dominate their market online with a fully custom, enterprise-grade web presence.</p>
            <ul style="list-style:none; padding:0; margin:0 0 28px; display:flex; flex-direction:column; gap:10px;">
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Unlimited pages</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Full custom UI/UX design</li>
              <li style="display:flex; gap:10px; align-items:flex-start; font-size:0.875rem; color:#242729;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;"><polyline points="20 6 9 17 4 12"/></svg>Complex integrations (CRM, e-commerce)</li>
