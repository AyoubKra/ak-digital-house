---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead
      title="Website Design & Development — AK Digital House | Raleigh, NC"
      description="Custom website design built to convert. AK Digital House creates fast, mobile-first, SEO-ready websites for growing businesses in Raleigh and across North Carolina."
    />
    <link rel="canonical" href="https://www.akdigitalhouse.com/services/website-design-maintenance" />

    <!-- JSON-LD: Service + LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "name": "Website Design & Maintenance",
          "description": "Custom, conversion-focused website design and development for growing businesses. Includes mobile-first design, performance optimization, SEO-ready structure, and ongoing maintenance.",
          "provider": {
            "@type": "LocalBusiness",
            "name": "AK Digital House LLC",
            "url": "https://www.akdigitalhouse.com",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Raleigh",
              "addressRegion": "NC",
              "addressCountry": "US"
            },
            "email": "contact@akdigitalhouse.com"
          },
          "areaServed": {
            "@type": "State",
            "name": "North Carolina"
          },
          "url": "https://www.akdigitalhouse.com/services/website-design-maintenance"
        },
        {
          "@type": "LocalBusiness",
          "name": "AK Digital House LLC",
          "url": "https://www.akdigitalhouse.com",
          "logo": "https://www.akdigitalhouse.com/logo-color.png",
          "image": "https://www.akdigitalhouse.com/logo-color.png",
          "description": "Full-service digital marketing agency specializing in web design, SEO, paid ads, and branding for growing businesses.",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Raleigh",
            "addressRegion": "NC",
            "addressCountry": "US"
          },
          "email": "contact@akdigitalhouse.com",
          "sameAs": [
            "https://www.instagram.com/akdigitalhouse/",
            "https://www.facebook.com/AKDigitalhousellc",
            "https://www.linkedin.com/company/ak-digital-house"
          ]
        }
      ]
    }
    </script>
  </head>

  <body style="margin:0; font-family:'Plus Jakarta Sans',system-ui,sans-serif; color:#242729; background:#fff;">
    <Navigation />

    <!-- ─── 1. HERO ─── -->
    <section class="hero-section">
      <div class="hero-inner">
        <!-- Left: Content -->
        <div class="hero-content">
          <h1 class="hero-label">Website Design &amp; Development</h1>
          <h2 class="hero-subheadline">Your Website Should Be Making You Money. <span class="hero-accent">Is It?</span></h2>
          <p class="hero-desc">
            Your next customer just landed on your website, waited 6 seconds for it to load, and left. Right now, that same customer is booking your competitor. We build fast, conversion-ready websites for Raleigh small businesses and startups — live in 3 weeks or less, built to turn every visitor into a long-term paying client.
          </p>
          <div class="hero-buttons">
            <a href="#contact" class="btn-primary">Launch My Website →</a>
            <a href="#packages" class="btn-secondary">See How It Works ↓</a>
          </div>
          <!-- Trust badges -->
          <div class="hero-badges">
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><polygon points="12 13.5 12.9 15.4 15 15.73 13.5 17.2 13.82 19.3 12 18.27 10.18 19.3 10.5 17.2 9 15.73 11.1 15.4 12 13.5"/></svg>
              <span>1yr Free Maintenance</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
              <span>&lt; 2s Loading</span>
            </div>
            <div class="badge">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 5c-1.5 0-2.8 1.4-3 2-3.5-1.5-11-.3-11 5 0 1.8 0 3 2 4.5V20h4v-2h3v2h4v-4c1-.5 1.7-1 2-2h2v-4h-2c0-1-.5-1.5-1-2z"/><path d="M2 9v1c0 1.1.9 2 2 2h1"/><circle cx="16" cy="11" r="0.5" fill="#d91e45"/></svg>
              <span>No Hidden Fees</span>
            </div>
          </div>
        </div>
        <!-- Right: Image -->
        <div class="hero-image-wrap">
          <img src="/Website design and development service.svg" alt="Web Design & Development" class="hero-image" />
        </div>
      </div>
    </section>

    <!-- ─── 5. GUARANTEES ─── -->
    <section style="background:#1a1c1e; padding:88px 24px;">
      <div style="max-width:1100px; margin:0 auto;">
        <div style="text-align:center; margin-bottom:56px;">
          <span style="display:inline-block; background:rgba(217,30,69,0.18); color:#d91e45; font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:6px 16px; border-radius:100px; margin-bottom:16px;">Our Commitments</span>
          <h2 style="font-size:clamp(1.75rem,3vw,2.25rem); font-weight:800; color:#fff; margin:0 0 16px;">What We Guarantee</h2>
          <p style="font-size:0.9375rem; color:rgba(255,255,255,0.55); max-width:520px; margin:0 auto; line-height:1.75;">We put our reputation behind every project. These aren't marketing claims — they're our operating standard.</p>
        </div>
        <div class="guarantee-grid" style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">

          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:32px 24px; text-align:center;">
            <div style="width:52px; height:52px; background:rgba(217,30,69,0.15); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3 style="font-size:1.0625rem; font-weight:700; color:#fff; margin:0 0 10px;">You Own Everything</h3>
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); line-height:1.75; margin:0;">Full ownership of all code, content, and assets from day one. No lock-in, ever.</p>
          </div>

          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:32px 24px; text-align:center;">
            <div style="width:52px; height:52px; background:rgba(217,30,69,0.15); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <h3 style="font-size:1.0625rem; font-weight:700; color:#fff; margin:0 0 10px;">On-Time Delivery</h3>
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); line-height:1.75; margin:0;">We set realistic timelines and keep them. You'll always know where your project stands.</p>
          </div>

          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:32px 24px; text-align:center;">
            <div style="width:52px; height:52px; background:rgba(217,30,69,0.15); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <h3 style="font-size:1.0625rem; font-weight:700; color:#fff; margin:0 0 10px;">Transparent Communication</h3>
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); line-height:1.75; margin:0;">Weekly updates, direct access to your project lead — no vague status emails.</p>
          </div>

          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:32px 24px; text-align:center;">
            <div style="width:52px; height:52px; background:rgba(217,30,69,0.15); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3 style="font-size:1.0625rem; font-weight:700; color:#fff; margin:0 0 10px;">Mobile-First, Always</h3>
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); line-height:1.75; margin:0;">Every site we ship looks and works perfectly on any screen — phone, tablet, or desktop.</p>
          </div>

          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:32px 24px; text-align:center;">
            <div style="width:52px; height:52px; background:rgba(217,30,69,0.15); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <h3 style="font-size:1.0625rem; font-weight:700; color:#fff; margin:0 0 10px;">Built for Performance</h3>
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); line-height:1.75; margin:0;">We target 90+ PageSpeed scores. Fast sites rank better, convert better, and retain visitors longer.</p>
          </div>

          <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:32px 24px; text-align:center;">
            <div style="width:52px; height:52px; background:rgba(217,30,69,0.15); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </div>
            <h3 style="font-size:1.0625rem; font-weight:700; color:#fff; margin:0 0 10px;">No Surprise Fees</h3>
            <p style="font-size:0.875rem; color:rgba(255,255,255,0.5); line-height:1.75; margin:0;">Clear scoping upfront means no bill shock at the end. We agree on scope before a single line is written.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ─── 2. SUB-SERVICES ─── -->
    <section class="sub-services-section">
      <div class="sub-services-inner">

        <div class="sub-services-header">
          <span style="display:inline-block; background:rgba(217,30,69,0.1); color:#d91e45; font-size:0.75rem; font-weight:700; letter-spacing:0.12em; text-transform:uppercase; padding:6px 16px; border-radius:100px; margin-bottom:16px;">What We Build</span>
          <h2 class="sub-h2">One Website Type Won't Fit Every Goal. We Build the Right One for Yours.</h2>
          <p class="sub-subtext">Whether you need a campaign page that converts, a store that sells, or a brand presence that ranks — we scope the build around the outcome, not a template.</p>
        </div>

        <div class="sub-grid">

          <!-- Card 1 — Landing Pages -->
          <div class="sub-card">
            <div class="sub-card-top">
              <span class="sub-card-num">01</span>
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <h3 class="sub-card-title">High-Converting Landing Pages</h3>
            <p class="sub-card-tagline">Turn Ad Spend Into Booked Clients</p>
            <p class="sub-card-desc"> One page. One goal. More clients. We build fast, focused landing pages that turn your ad traffic into phone calls, form fills, and booked appointments, nothing else gets in the way.</p>            <ul class="sub-card-features">
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>One page, one goal</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">no distractions, just conversions</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Loads in under 2 seconds</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">fast enough to keep every visitor</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Mobile-perfect on any screen</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">phones, tablets, desktops</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Instant lead notifications</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">know the second someone reaches out</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Ad-ready from day one</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">Google, Meta, and TikTok plug straight in</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Tracks every click and sale</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">full visibility on what's working</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Built-in contact and booking forms</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">no third-party tools needed</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>SEO-optimized from the ground up</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">ranks even without paid ads</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Update anything yourself</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">no developer needed for changes</small></span></li>
              <li><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:4px;"><polyline points="20 6 9 17 4 12"/></svg><span><strong>Designed to build trust fast</strong><br/><small style="color:#6b7280;font-size:0.8rem;line-height:1.5;">social proof, guarantees, and CTAs in the right places</small></span></li>
            </ul>
            <div class="sub-card-divider"></div>
            <a href="#contact" class="sub-card-cta">Start Generating Leads <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#d91e45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </div>

