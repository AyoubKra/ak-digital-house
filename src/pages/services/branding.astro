---
import BaseHead from '../../components/BaseHead.astro';
import Navigation from '../../components/ui/Navigation.astro';
import Footer from '../../components/ui/Footer.astro';

const deliverables = [
  { icon: '🎨', title: 'Logo & Visual Identity', desc: 'A distinctive logo and complete visual system — colors, typography, iconography — that reflects who you are.' },
  { icon: '📖', title: 'Brand Guidelines', desc: 'A clear, comprehensive brand guide so your team and partners always represent you consistently.' },
  { icon: '✍️', title: 'Brand Voice & Messaging', desc: 'The words that define your brand — taglines, positioning statements, and tone of voice.' },
  { icon: '📄', title: 'Marketing Collateral', desc: 'Business cards, presentations, social templates, and other assets designed to impress.' },
  { icon: '🌐', title: 'Website Design', desc: 'A website that looks and feels like your brand — visually unified and built to convert.' },
  { icon: '📱', title: 'Social Media Assets', desc: 'Profile images, cover photos, and post templates that make your brand shine on every platform.' },
];

const process = [
  { step: '01', title: 'Brand Discovery', desc: 'We explore your mission, values, audience, and competitive landscape to find what makes you unique.' },
  { step: '02', title: 'Strategy & Positioning', desc: 'We define your brand positioning, messaging, and personality — the foundation everything else is built on.' },
  { step: '03', title: 'Creative Design', desc: 'We design your visual identity — exploring multiple directions before refining to a final system.' },
  { step: '04', title: 'Delivery & Rollout', desc: 'We hand off all files and guidelines and help you roll out the new brand across your channels.' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Branding & Creative Design — AK Digital House"
      description="We build brand identities that are distinctive, memorable, and built to last. Logo, visual system, messaging and more."
    />
  </head>
  <body>
    <Navigation />

    <!-- Hero -->
    <section class="service-hero">
      <div class="section-inner">
        <span class="service-label">Service</span>
        <h1>Branding & Creative Design</h1>
        <p class="hero-sub">A brand that looks the part, says the right things, and earns instant trust</p>
        <a href="/contact" class="hero-cta">Get a Free Quote</a>
      </div>
    </section>

    <!-- Overview -->
    <section class="overview-section">
      <div class="section-inner overview-grid">
        <div class="overview-text">
          <h2>Your brand is your first impression — make it count</h2>
          <p>A strong brand builds credibility before you say a word. It's the difference between a prospect trusting you or scrolling past.</p>
          <p>We design brand identities that are visually distinctive, strategically sound, and built for the long term. Whether you're starting from scratch or refreshing an existing brand, we'll make you look like the leader in your market.</p>
        </div>
        <div class="overview-list">
          <h3>What's included</h3>
          <ul>
            <li>Brand strategy & positioning</li>
            <li>Logo design (multiple concepts)</li>
            <li>Color palette & typography</li>
            <li>Brand guidelines document</li>
            <li>Brand voice & messaging</li>
            <li>Social media assets</li>
            <li>Business card & stationery</li>
            <li>All source files (AI, SVG, PNG)</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Deliverables -->
    <section class="features-section">
      <div class="section-inner">
        <h2 class="section-title">What we deliver</h2>
        <div class="features-grid">
          {deliverables.map(d => (
            <div class="feature-card">
              <span class="feature-icon">{d.icon}</span>
              <h3>{d.title}</h3>
              <p>{d.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="process-section">
      <div class="section-inner">
        <h2 class="section-title">Our branding process</h2>
        <div class="process-grid">
          {process.map(p => (
            <div class="process-card">
              <span class="process-step">{p.step}</span>
              <h3>{p.title}</h3>
              <p>{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="section-inner cta-inner">
        <h2>Ready for a brand that stands out?</h2>
        <p>Book a free strategy call and let's talk about your vision.</p>
        <a href="/contact" class="cta-btn">Book a Free Strategy Call</a>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  body { margin: 0; font-family: "Plus Jakarta Sans", system-ui, sans-serif; color: #242729; background: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }

  .service-hero { background: linear-gradient(160deg, #fde8ed 0%, #fff 60%); padding: 96px 24px 80px; text-align: center; }
  .service-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #D91E45; background: rgba(217,30,69,0.08); padding: 4px 12px; border-radius: 999px; }
  .service-hero h1 { font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 700; color: #1A1C1E; margin: 20px 0 16px; line-height: 1.2; }
  .hero-sub { font-size: clamp(1rem, 1.2vw, 1.125rem); color: #555; line-height: 1.6; max-width: 560px; margin: 0 auto 32px; }
  .hero-cta { display: inline-flex; align-items: center; padding: 16px 32px; background: #D91E45; color: #fff; font-size: 1rem; font-weight: 500; border-radius: 1000px; text-decoration: none; transition: transform 0.2s ease, filter 0.2s ease, box-shadow 0.2s ease; }
  .hero-cta:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(217,30,69,0.25); color: #fff; }

  .overview-section { padding: 80px 24px; }
  .overview-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .overview-text h2 { font-size: clamp(1.5rem, 2vw, 1.75rem); font-weight: 700; color: #1A1C1E; margin: 0 0 20px; line-height: 1.2; }
  .overview-text p { font-size: 0.9375rem; color: #555; line-height: 1.8; margin: 0 0 16px; }
  .overview-list h3 { font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #D91E45; margin: 0 0 16px; }
  .overview-list ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .overview-list li { font-size: 0.9375rem; color: #242729; padding-left: 20px; position: relative; line-height: 1.5; }
  .overview-list li::before { content: '✓'; position: absolute; left: 0; color: #D91E45; font-weight: 700; }

  .features-section { background: #F9F9F9; padding: 80px 24px; }
  .section-title { font-size: clamp(1.5rem, 2vw, 1.75rem); font-weight: 700; color: #1A1C1E; text-align: center; margin: 0 0 48px; line-height: 1.2; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .feature-card { background: #fff; border: 1px solid #E0E0E0; border-radius: 12px; padding: 28px 24px; display: flex; flex-direction: column; gap: 12px; transition: box-shadow 0.2s ease, transform 0.2s ease; }
  .feature-card:hover { box-shadow: 0 10px 30px rgba(217,30,69,0.1); transform: translateY(-2px); }
  .feature-icon { font-size: 1.75rem; }
  .feature-card h3 { font-size: 1rem; font-weight: 700; color: #1A1C1E; margin: 0; }
  .feature-card p { font-size: 0.9375rem; color: #555; line-height: 1.6; margin: 0; }

  .process-section { padding: 80px 24px; }
  .process-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .process-card { border: 1px solid #E0E0E0; border-radius: 12px; padding: 28px 24px; display: flex; flex-direction: column; gap: 12px; }
  .process-step { font-size: 2rem; font-weight: 700; color: #D91E45; line-height: 1; }
  .process-card h3 { font-size: 1rem; font-weight: 700; color: #1A1C1E; margin: 0; }
  .process-card p { font-size: 0.9375rem; color: #555; line-height: 1.6; margin: 0; }

  .cta-section { background: #1A1C1E; padding: 80px 24px; }
  .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .cta-inner h2 { font-size: clamp(1.5rem, 2.5vw, 1.75rem); font-weight: 700; color: #fff; margin: 0; }
  .cta-inner p { font-size: 1rem; color: rgba(255,255,255,0.65); margin: 0; }
  .cta-btn { display: inline-flex; align-items: center; padding: 16px 32px; background: #D91E45; color: #fff; font-size: 1rem; font-weight: 500; border-radius: 1000px; text-decoration: none; transition: transform 0.2s ease, filter 0.2s ease, box-shadow 0.2s ease; }
  .cta-btn:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(217,30,69,0.25); color: #fff; }

  @media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } .process-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .overview-grid { grid-template-columns: 1fr; gap: 40px; } .overview-section, .features-section, .process-section, .cta-section { padding: 48px 16px; } .service-hero { padding: 64px 16px 48px; } }
  @media (max-width: 560px) { .features-grid { grid-template-columns: 1fr; } .process-grid { grid-template-columns: 1fr; } }
</style>
