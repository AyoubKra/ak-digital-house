---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/ui/Navigation.astro';
import Footer from '../components/ui/Footer.astro';

const lastUpdated = 'April 9, 2026';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Terms & Conditions — AK Digital House"
      description="Terms and conditions governing the use of AK Digital House services and website."
    />
  </head>
  <body>
    <Navigation />

    <section class="page-hero">
      <div class="section-inner">
        <h1 class="page-hero-headline">Terms & Conditions</h1>
        <p class="page-hero-sub">Last updated: {lastUpdated}</p>
      </div>
    </section>

    <section class="legal-section">
      <div class="section-inner prose">

        <h2>1. Acceptance of Terms</h2>
        <p>By accessing or using the website at akdigitalhouse.com or engaging our services, you agree to be bound by these Terms & Conditions. If you do not agree, please do not use our site or services.</p>

        <h2>2. Services</h2>
        <p>AK Digital House LLC provides digital marketing services including web design, SEO, paid advertising, and branding. Specific deliverables, timelines, and pricing are defined in individual client agreements or proposals.</p>

        <h2>3. Intellectual Property</h2>
        <p>All content on this website — including text, graphics, logos, and images — is the property of AK Digital House LLC and is protected by applicable copyright and trademark laws. You may not reproduce or distribute our content without written permission.</p>
        <p>Upon full payment, clients receive ownership of all deliverables created specifically for their project, except for third-party assets (stock images, fonts, plugins) which are subject to their respective licenses.</p>

        <h2>4. Client Responsibilities</h2>
        <p>Clients are responsible for providing accurate information, timely feedback, and any required materials (such as logos, content, or brand assets) necessary for project completion. Delays caused by client inaction may affect project timelines.</p>

        <h2>5. Payment Terms</h2>
        <p>Payment terms are specified in individual client agreements. Late payments may result in suspension of services. All fees are non-refundable unless otherwise stated in writing.</p>

        <h2>6. Limitation of Liability</h2>
        <p>AK Digital House LLC shall not be liable for any indirect, incidental, or consequential damages arising from the use of our services or website. Our total liability for any claim shall not exceed the amount paid by the client in the preceding 30 days.</p>

        <h2>7. Confidentiality</h2>
        <p>Both parties agree to keep confidential any non-public information disclosed during the engagement. This obligation survives the termination of any client relationship.</p>

        <h2>8. Termination</h2>
        <p>Either party may terminate a service agreement with 30 days written notice. Upon termination, all outstanding invoices become immediately due and payable.</p>

        <h2>9. Governing Law</h2>
        <p>These Terms & Conditions are governed by the laws of the State of North Carolina. Any disputes shall be resolved in the courts of Wake County, North Carolina.</p>

        <h2>10. Changes to Terms</h2>
        <p>We reserve the right to update these Terms & Conditions at any time. Continued use of our services after changes constitutes acceptance of the revised terms.</p>

        <h2>11. Contact</h2>
        <p>For questions about these terms, contact us at:<br />
        <strong>AK Digital House LLC</strong><br />
        Raleigh, North Carolina<br />
        <a href="mailto:contact@akdigitalhouse.com">contact@akdigitalhouse.com</a></p>

      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  body { margin: 0; font-family: "Plus Jakarta Sans", system-ui, sans-serif; color: #242729; background: #fff; }
  .section-inner { max-width: 760px; margin: 0 auto; }

  .page-hero { background: #F9F9F9; padding: 64px 24px; text-align: center; }
  .page-hero-headline { font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 700; color: #1A1C1E; line-height: 1.2; margin: 0 0 12px; }
  .page-hero-sub { font-size: 0.9375rem; color: #999; margin: 0; }

  .legal-section { padding: 64px 24px 80px; }

  .prose h2 { font-size: 1.125rem; font-weight: 700; color: #1A1C1E; margin: 40px 0 12px; }
  .prose h2:first-child { margin-top: 0; }
  .prose p { font-size: 0.9375rem; color: #555; line-height: 1.8; margin: 0 0 16px; }
  .prose ul { padding-left: 20px; margin: 0 0 16px; }
  .prose li { font-size: 0.9375rem; color: #555; line-height: 1.8; margin-bottom: 6px; }
  .prose a { color: #D91E45; text-decoration: none; }
  .prose a:hover { text-decoration: underline; }

  @media (max-width: 640px) { .legal-section { padding: 40px 16px 60px; } .page-hero { padding: 48px 16px; } }
</style>
