---
import BaseHead from '../components/BaseHead.astro';
import Card from '../components/ui/Card.astro';
import Footer from '../components/ui/Footer.astro';
import Navigation from '../components/ui/Navigation.astro';
import Button from '../components/ui/Button.astro';

const services = [
  {
    icon: '🎨',
    title: 'Web Design & Development',
    description: 'Create beautiful, conversion-optimized websites that turn visitors into customers.',
    href: '/services',
  },
  {
    icon: '📈',
    title: 'SEO Optimization',
    description: 'Improve your search rankings and drive sustainable organic traffic to your business.',
    href: '/services',
  },
  {
    icon: '💡',
    title: 'Digital Marketing Strategy',
    description: 'Strategic campaigns that drive measurable results and long-term growth.',
    href: '/services',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="AK Digital House — Digital Marketing Agency"
      description="We build websites that convert and digital strategies that scale."
    />
  </head>
  <body>

    <!-- 1. NAVIGATION -->
    <Navigation />

    <!-- 2. HERO -->
    <section class="hero">
      <div class="hero-inner">
        <h1 class="hero-headline">
          Digital Marketing Agency for Growth-Focused Businesses
        </h1>
        <p class="hero-subheadline">
          We build websites that convert and digital strategies that scale
        </p>
        <Button href="/contact" variant="primary" size="lg">
          Start Your Project
        </Button>
      </div>
    </section>

    <!-- 3. SERVICES -->
    <section class="services">
      <div class="section-inner">
        <h2 class="section-title">Our Services</h2>
        <div class="services-grid">
          {services.map(service => (
            <div class="service-card">
              <div class="service-icon">{service.icon}</div>
              <Card
                title={service.title}
                description={service.description}
                href={service.href}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. CTA SECTION -->
    <section class="cta-section">
      <div class="section-inner cta-inner">
        <h2 class="cta-headline">Ready to grow your business?</h2>
        <p class="cta-subheadline">
          Let's discuss your project and build something amazing
        </p>
        <Button href="/contact" variant="primary" size="lg">
          Book a Consultation
        </Button>
      </div>
    </section>

    <!-- 5. FOOTER -->
    <Footer />

  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    color: #202020;
    background: #fff;
  }

  /* ── Hero ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(160deg, #FACC15 0%, #ffffff 55%);
    padding: 48px 24px;
  }

  .hero-inner {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .hero-headline {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
    color: #202020;
    margin: 0;
  }

  .hero-subheadline {
    font-size: clamp(0.9375rem, 1vw, 1rem);
    color: #555;
    line-height: 1.6;
    margin: 0;
    max-width: 560px;
  }

  /* ── Services ── */
  .services {
    padding: 80px 24px;
    background: #fff;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(1.5rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: #202020;
    text-align: center;
    margin: 0 0 48px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .service-card {
    display: flex;
    flex-direction: column;
  }

  .service-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  /* ── CTA Section ── */
  .cta-section {
    background: #1A1C1E;
    padding: 80px 24px;
  }

  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .cta-headline {
    font-size: clamp(1.5rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: #ffffff;
    margin: 0;
    line-height: 1.2;
  }

  .cta-subheadline {
    font-size: clamp(0.9375rem, 1vw, 1rem);
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin: 0;
    max-width: 480px;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .hero {
      min-height: auto;
      padding: 80px 16px;
    }

    .services,
    .cta-section {
      padding: 48px 16px;
    }
  }
</style>
