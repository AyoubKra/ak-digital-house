---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/ui/Navigation.astro';
import Footer from '../components/ui/Footer.astro';

const posts = [
  {
    title: '5 Website Mistakes That Are Costing You Leads',
    date: 'April 2, 2026',
    category: 'Web Design',
    excerpt: 'Most business websites lose visitors in the first 10 seconds. Here are the five most common mistakes we see and how to fix them fast.',
    href: '/blog',
  },
  {
    title: 'How to Rank on Google in 2026: A Practical SEO Guide',
    date: 'March 28, 2026',
    category: 'SEO',
    excerpt: 'Search algorithms have changed dramatically. This guide breaks down what actually works today for small and mid-size businesses.',
    href: '/blog',
  },
  {
    title: 'Paid Ads vs. Organic SEO: Which One Is Right for You?',
    date: 'March 15, 2026',
    category: 'Digital Marketing',
    excerpt: 'Both channels can drive growth — but they work differently. We break down the trade-offs so you can make the right investment decision.',
    href: '/blog',
  },
  {
    title: 'The Brand Identity Checklist Every Business Needs',
    date: 'March 5, 2026',
    category: 'Branding',
    excerpt: 'A strong brand is more than a logo. Walk through the 10 elements that make a brand instantly recognizable and trustworthy.',
    href: '/blog',
  },
  {
    title: 'Why Your Landing Page Isn\'t Converting (And How to Fix It)',
    date: 'February 20, 2026',
    category: 'Web Design',
    excerpt: 'High traffic with low conversions is a design problem, not a traffic problem. Learn the principles behind pages that convert.',
    href: '/blog',
  },
  {
    title: 'Lead Generation for B2B: Strategies That Actually Work',
    date: 'February 8, 2026',
    category: 'Digital Marketing',
    excerpt: 'B2B lead gen is different from B2C. We share the exact frameworks we use for clients to fill their pipeline with qualified leads.',
    href: '/blog',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Blog — AK Digital House"
      description="Digital marketing tips, SEO guides, and web design insights from the AK Digital House team."
    />
  </head>
  <body>
    <Navigation />

    <section class="page-hero">
      <div class="section-inner">
        <h1 class="page-hero-headline">Blog & Resources</h1>
        <p class="page-hero-sub">Tips, insights, and strategies from our team</p>
      </div>
    </section>

    <section class="blog-section">
      <div class="section-inner">
        <div class="blog-grid">
          {posts.map(post => (
            <article class="post-card">
              <div class="post-body">
                <span class="post-category">{post.category}</span>
                <h2 class="post-title"><a href={post.href}>{post.title}</a></h2>
                <p class="post-excerpt">{post.excerpt}</p>
                <div class="post-footer">
                  <span class="post-date">{post.date}</span>
                  <a href={post.href} class="post-link">Read more →</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  body { margin: 0; font-family: "Plus Jakarta Sans", system-ui, sans-serif; color: #242729; background: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }

  .page-hero { background: #F9F9F9; padding: 72px 24px; text-align: center; }
  .page-hero-headline { font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 700; color: #1A1C1E; line-height: 1.2; margin: 0 0 16px; }
  .page-hero-sub { font-size: clamp(0.9375rem, 1vw, 1rem); color: #555; line-height: 1.6; margin: 0; }

  .blog-section { padding: 80px 24px; }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .post-card {
    background: #fff;
    border: 1px solid #E0E0E0;
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .post-card:hover {
    box-shadow: 0 10px 30px rgba(217, 30, 69, 0.1);
    transform: translateY(-2px);
  }

  .post-body { padding: 28px; display: flex; flex-direction: column; gap: 12px; height: 100%; box-sizing: border-box; }

  .post-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #D91E45;
    background: rgba(217, 30, 69, 0.07);
    padding: 3px 10px;
    border-radius: 999px;
    align-self: flex-start;
  }

  .post-title { font-size: 1.0625rem; font-weight: 700; color: #1A1C1E; margin: 0; line-height: 1.35; }
  .post-title a { color: inherit; text-decoration: none; transition: color 0.15s ease; }
  .post-title a:hover { color: #D91E45; }

  .post-excerpt { font-size: 0.9375rem; color: #555; line-height: 1.6; margin: 0; flex: 1; }

  .post-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 16px; border-top: 1px solid #F0F0F0; }

  .post-date { font-size: 0.8125rem; color: #999; }
  .post-link { font-size: 0.875rem; font-weight: 600; color: #D91E45; text-decoration: none; }
  .post-link:hover { text-decoration: underline; }

  @media (max-width: 900px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) {
    .blog-grid { grid-template-columns: 1fr; }
    .blog-section { padding: 48px 16px; }
    .page-hero { padding: 48px 16px; }
  }
</style>
