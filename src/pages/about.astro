---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/ui/Navigation.astro';
import Footer from '../components/ui/Footer.astro';
import Button from '../components/ui/Button.astro';

const team = [
  {
    name: 'AK Digital House',
    role: 'Digital Marketing Agency',
    bio: 'We are a full-service digital marketing agency based in Raleigh, North Carolina. We help growth-focused businesses build a strong online presence and scale their revenue through smart design and strategy.',
  },
];

const values = [
  {
    icon: '🎯',
    title: 'Results-Driven',
    description: 'Every decision we make is tied to measurable outcomes. We focus on what moves the needle for your business.',
  },
  {
    icon: '🤝',
    title: 'Partnership',
    description: 'We treat every client like a long-term partner. Your growth is our growth, and we are invested in your success.',
  },
  {
    icon: '⚡',
    title: 'Speed & Quality',
    description: 'We move fast without cutting corners. Great work delivered on time, every time.',
  },
  {
    icon: '🔍',
    title: 'Transparency',
    description: 'No black boxes. You always know what we are working on, why, and what results it is producing.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="About — AK Digital House"
      description="We are a digital marketing agency based in Raleigh, NC helping growth-focused businesses scale online."
    />
  </head>
  <body>

    <!-- NAVIGATION -->
    <Navigation />

    <!-- PAGE HERO -->
    <section class="page-hero">
      <div class="section-inner">
        <h1 class="page-hero-headline">About Us</h1>
        <p class="page-hero-sub">A digital agency built to grow your business</p>
      </div>
    </section>

    <!-- ABOUT SECTION -->
    <section class="about-section">
      <div class="section-inner about-grid">
        <div class="about-text">
          <h2 class="section-title">Who We Are</h2>
          <p>AK Digital House is a full-service digital marketing agency based in Raleigh, North Carolina. We partner with growth-focused businesses to build websites that convert, run marketing strategies that scale, and create digital experiences that make an impact.</p>
          <p>We combine thoughtful design, technical expertise, and data-driven strategy to deliver real, measurable results — not just deliverables.</p>
          <Button href="/contact" variant="primary" size="md">Work With Us</Button>
        </div>
        <div class="about-stats">
          <div class="stat-card">
            <span class="stat-number">50+</span>
            <span class="stat-label">Projects Delivered</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">3x</span>
            <span class="stat-label">Average ROI</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">100%</span>
            <span class="stat-label">Client Satisfaction</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">5+</span>
            <span class="stat-label">Years Experience</span>
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES SECTION -->
    <section class="values-section">
      <div class="section-inner">
        <div class="values-header">
          <h2 class="section-title">Our Values</h2>
          <p class="section-sub">The principles that guide everything we do</p>
        </div>
        <div class="values-grid">
          {values.map(value => (
            <div class="value-card">
              <span class="value-icon">{value.icon}</span>
              <h3 class="value-title">{value.title}</h3>
              <p class="value-desc">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="cta-section">
      <div class="section-inner cta-inner">
        <h2 class="cta-headline">Ready to work together?</h2>
        <p class="cta-sub">Let's build something great for your business.</p>
        <Button href="/contact" variant="primary" size="lg">Get in Touch</Button>
      </div>
    </section>

    <!-- FOOTER -->
    <Footer />

  </body>
</html>

<style>
  body {
    margin: 0;
    font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
    color: #202020;
    background: #fff;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Page Hero ── */
  .page-hero {
    background: #F5F5F5;
    padding: 72px 24px;
    text-align: center;
  }

  .page-hero-headline {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #202020;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .page-hero-sub {
    font-size: clamp(0.9375rem, 1vw, 1rem);
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  /* ── About Section ── */
  .about-section {
    padding: 80px 24px;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .about-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-text .section-title {
    margin: 0;
  }

  .about-text p {
    font-size: clamp(0.9375rem, 1vw, 1rem);
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .stat-card {
    background: #F5F5F5;
    border: 1px solid #E0E0E0;
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: #202020;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.875rem;
    color: #777;
    font-weight: 500;
  }

  /* ── Values Section ── */
  .values-section {
    background: #F5F5F5;
    padding: 80px 24px;
  }

  .values-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-title {
    font-size: clamp(1.5rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: #202020;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .section-sub {
    font-size: clamp(0.9375rem, 1vw, 1rem);
    color: #555;
    margin: 0;
    line-height: 1.6;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .value-card {
    background: #fff;
    border: 1px solid #E0E0E0;
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .value-icon {
    font-size: 1.75rem;
  }

  .value-title {
    font-size: 1rem;
    font-weight: 700;
    color: #202020;
    margin: 0;
    line-height: 1.2;
  }

  .value-desc {
    font-size: 0.9375rem;
    color: #555;
    line-height: 1.6;
    margin: 0;
  }

  /* ── CTA Section ── */
  .cta-section {
    background: #1A1C1E;
    padding: 80px 24px;
  }

  .cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .cta-headline {
    font-size: clamp(1.5rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.2;
  }

  .cta-sub {
    font-size: clamp(0.9375rem, 1vw, 1rem);
    color: rgba(255,255,255,0.65);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .values-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .about-section,
    .values-section,
    .cta-section {
      padding: 48px 16px;
    }

    .page-hero {
      padding: 48px 16px;
    }
  }

  @media (max-width: 480px) {
    .values-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
