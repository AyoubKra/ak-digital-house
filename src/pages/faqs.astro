---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/ui/Navigation.astro';
import Footer from '../components/ui/Footer.astro';

const faqs = [
  {
    category: 'General',
    items: [
      {
        q: 'What services does AK Digital House offer?',
        a: 'We offer four core services: Branding & Creative Design, Paid Ads & Lead Generation, SEO & Website Optimization, and Website Design & Maintenance. Each service is tailored to help growth-focused businesses build a stronger online presence.',
      },
      {
        q: 'Who do you work with?',
        a: 'We primarily work with small to mid-size B2B and SaaS companies that are serious about growing online. Whether you\'re just starting out or looking to scale, we have a solution that fits your stage.',
      },
      {
        q: 'Where are you based?',
        a: 'We are based in Raleigh, North Carolina, but we work with clients across the United States remotely.',
      },
    ],
  },
  {
    category: 'Web Design',
    items: [
      {
        q: 'How long does it take to build a website?',
        a: 'A typical website project takes 4–8 weeks from discovery to launch, depending on scope and complexity. We\'ll give you a clear timeline during our initial consultation.',
      },
      {
        q: 'Will my website be mobile-friendly?',
        a: 'Yes — every website we build is fully responsive and tested on mobile, tablet, and desktop devices. Mobile-first design is a core part of our process.',
      },
      {
        q: 'Do you offer website maintenance after launch?',
        a: 'Yes. We offer ongoing Website Design & Maintenance packages to keep your site updated, secure, and performing at its best.',
      },
    ],
  },
  {
    category: 'SEO & Marketing',
    items: [
      {
        q: 'How long does SEO take to show results?',
        a: 'SEO is a long-term investment. Most clients start seeing meaningful improvements in 3–6 months, with significant growth typically occurring at the 6–12 month mark.',
      },
      {
        q: 'Do you run paid ads (Google, Meta)?',
        a: 'Yes. Our Paid Ads & Lead Generation service covers Google Ads, Meta Ads (Facebook & Instagram), and other paid channels. We handle strategy, setup, management, and reporting.',
      },
      {
        q: 'How do you measure results?',
        a: 'We set clear KPIs at the start of every engagement — traffic, leads, conversions, ROI — and provide monthly reports so you always know what\'s working.',
      },
    ],
  },
  {
    category: 'Pricing & Process',
    items: [
      {
        q: 'How much do your services cost?',
        a: 'Pricing depends on the scope of your project. We offer customized quotes after a free strategy call where we learn about your goals and challenges. Book a call to get started.',
      },
      {
        q: 'What does the onboarding process look like?',
        a: 'We start with a Discovery call to understand your business, then move into Strategy, Execution, and Growth phases. You\'re involved at every step and always know what\'s happening.',
      },
      {
        q: 'Do you require long-term contracts?',
        a: 'For ongoing services like SEO and paid ads, we recommend a minimum 3-month commitment to see meaningful results. Project-based work like web design is billed per project.',
      },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="FAQs — AK Digital House"
      description="Answers to the most common questions about our services, process, and pricing."
    />
  </head>
  <body>
    <Navigation />

    <main>

    <section class="page-hero">
      <div class="section-inner">
        <h1 class="page-hero-headline">Frequently Asked Questions</h1>
        <p class="page-hero-sub">Everything you need to know before getting started</p>
      </div>
    </section>

    <section class="faqs-section">
      <div class="section-inner">
        {faqs.map(group => (
          <div class="faq-group">
            <h2 class="faq-category">{group.category}</h2>
            <div class="faq-list">
              {group.items.map((item, i) => (
                <details class="faq-item">
                  <summary class="faq-question">
                    {item.q}
                    <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                  </summary>
                  <div class="faq-answer">
                    <p>{item.a}</p>
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="cta-section">
      <div class="section-inner cta-inner">
        <h2 class="cta-headline">Still have questions?</h2>
        <p class="cta-sub">Book a free strategy call and we'll answer everything.</p>
        <a href="/contact" class="cta-btn">Book a Free Strategy Call</a>
      </div>
    </section>

    </main>

    <Footer />
  </body>
</html>

<style>
  body { margin: 0; font-family: "Plus Jakarta Sans", system-ui, sans-serif; color: #242729; background: #fff; }
  .section-inner { max-width: 860px; margin: 0 auto; }

  .page-hero { background: #F9F9F9; padding: 72px 24px; text-align: center; }
  .page-hero-headline { font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 700; color: #1A1C1E; line-height: 1.2; margin: 0 0 16px; }
  .page-hero-sub { font-size: clamp(0.9375rem, 1vw, 1rem); color: #555; line-height: 1.6; margin: 0; }

  .faqs-section { padding: 80px 24px; }

  .faq-group { margin-bottom: 48px; }

  .faq-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #D91E45;
    margin: 0 0 20px;
  }

  .faq-list { display: flex; flex-direction: column; gap: 8px; }

  .faq-item {
    border: 1px solid #E0E0E0;
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }
  .faq-item[open] { border-color: #D91E45; }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    font-size: 1rem;
    font-weight: 600;
    color: #1A1C1E;
    cursor: pointer;
    list-style: none;
    gap: 16px;
    transition: background-color 0.15s ease;
  }
  .faq-question:hover { background: #F9F9F9; }
  .faq-question::-webkit-details-marker { display: none; }

  .faq-chevron { flex-shrink: 0; transition: transform 0.25s ease; color: #D91E45; }
  .faq-item[open] .faq-chevron { transform: rotate(180deg); }

  .faq-answer { padding: 0 24px 20px; }
  .faq-answer p { font-size: 0.9375rem; color: #555; line-height: 1.7; margin: 0; }

  /* CTA */
  .cta-section { background: #1A1C1E; padding: 80px 24px; }
  .cta-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 20px; }
  .cta-headline { font-size: clamp(1.5rem, 2.5vw, 1.75rem); font-weight: 700; color: #fff; margin: 0; line-height: 1.2; }
  .cta-sub { font-size: clamp(0.9375rem, 1vw, 1rem); color: rgba(255,255,255,0.65); margin: 0; line-height: 1.6; }
  .cta-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 16px 32px; background: #D91E45; color: #ffffff; font-size: 1rem;
    font-weight: 500; border-radius: 1000px; text-decoration: none;
    transition: transform 0.2s ease, filter 0.2s ease, box-shadow 0.2s ease;
  }
  .cta-btn:hover { filter: brightness(1.1); transform: translateY(-2px); box-shadow: 0 10px 20px rgba(217,30,69,0.25); color: #ffffff; }

  @media (max-width: 640px) {
    .faqs-section { padding: 48px 16px; }
    .page-hero { padding: 48px 16px; }
    .cta-section { padding: 48px 16px; }
    .faq-question { padding: 16px 20px; font-size: 0.9375rem; }
    .faq-answer { padding: 0 20px 16px; }
  }
</style>
