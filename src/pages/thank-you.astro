---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/ui/Navigation.astro';
import Footer from '../components/ui/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Thank You — AK Digital House"
      description="We received your message and will get back to you within 1 business day."
    />

    <!-- Meta Pixel: Lead conversion -->
    <script is:inline>
      if (typeof fbq !== 'undefined') {
        fbq('track', 'Lead');
      }
    </script>

    <!-- TikTok Pixel: Lead conversion -->
    <script is:inline>
      if (typeof ttq !== 'undefined') {
        ttq.track('SubmitForm');
      }
    </script>

    <!-- GA4: form_submission event (requires GA4 to be installed) -->
    <script is:inline>
      if (typeof gtag !== 'undefined') {
        gtag('event', 'form_submission', {
          event_category: 'Contact',
          event_label: 'Web Design Inquiry'
        });
      }
    </script>
  </head>
  <body>
    <Navigation />

    <main>

    <section class="ty-section">
      <div class="ty-inner">
        <div class="ty-icon">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#D91E45" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <h1>Thank You — We Got Your Message</h1>
        <p class="ty-body">We will review your project and get back to you within 1 business day.</p>
        <a href="/" class="ty-btn">
          Back to Home
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    </main>

    <Footer />
  </body>
</html>

<style>
  body { margin: 0; font-family: "Plus Jakarta Sans", system-ui, sans-serif; color: #242729; background: #fff; }

  .ty-section {
    background: #fff;
    padding: 96px 24px;
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ty-inner {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .ty-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    background: rgba(217, 30, 69, 0.08);
    border-radius: 9999px;
  }

  h1 {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800;
    color: #1A1C1E;
    margin: 0;
    line-height: 1.2;
  }

  .ty-body {
    font-size: 1rem;
    color: #6b7280;
    line-height: 1.75;
    margin: 0;
  }

  .ty-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #D91E45;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    border-radius: 9999px;
    text-decoration: none;
    font-family: inherit;
    transition: filter 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ty-btn:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(217, 30, 69, 0.3);
  }
</style>
